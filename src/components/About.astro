<section id="especialidades" class="py-32 px-6 bg-black relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 right-0 w-96 h-96 bg-accent-primary/5 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-6xl mx-auto relative z-10">
    <!-- Header -->
    <div class="mb-20 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Mis Especialidades
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto font-light">
        Más de 3 años trabajando con tecnologías modernas para crear soluciones web escalables y eficientes
      </p>
    </div>

    <!-- 3 Specialty Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      <!-- Frontend Development -->
      <div class="group glass rounded-2xl p-8 border border-gray-800 hover:border-accent-primary/50 transition-all duration-300 hover:shadow-xl hover:shadow-accent-primary/10 animate-scale-in" style="animation-delay: 0s;">
        <div class="w-14 h-14 bg-accent-primary/10 rounded-lg flex items-center justify-center mb-6 group-hover:bg-accent-primary/20 transition-colors">
          <svg class="w-7 h-7 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a6 6 0 016 6v10a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a6 6 0 00-6-6H7a2 2 0 00-2 2v4a4 4 0 004 4z"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-3">Frontend Moderno</h3>
        <p class="text-gray-400 font-light mb-4 leading-relaxed">
          Diseño responsivo y experiencias de usuario excepcionales con React, Astro y Tailwind CSS
        </p>
        <ul class="space-y-2">
          <li class="text-sm text-gray-500 font-light">✦ React & Next.js</li>
          <li class="text-sm text-gray-500 font-light">✦ Astro Framework</li>
          <li class="text-sm text-gray-500 font-light">✦ Tailwind CSS</li>
        </ul>
      </div>

      <!-- Backend Development -->
      <div class="group glass rounded-2xl p-8 border border-gray-800 hover:border-accent-primary/50 transition-all duration-300 hover:shadow-xl hover:shadow-accent-primary/10 animate-scale-in" style="animation-delay: 0.1s;">
        <div class="w-14 h-14 bg-accent-primary/10 rounded-lg flex items-center justify-center mb-6 group-hover:bg-accent-primary/20 transition-colors">
          <svg class="w-7 h-7 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-3">Backend Robusto</h3>
        <p class="text-gray-400 font-light mb-4 leading-relaxed">
          APIs escalables y bases de datos eficientes con Node.js, Express y tecnologías cloud
        </p>
        <ul class="space-y-2">
          <li class="text-sm text-gray-500 font-light">✦ Node.js & Express</li>
          <li class="text-sm text-gray-500 font-light">✦ MongoDB & SQL</li>
          <li class="text-sm text-gray-500 font-light">✦ RESTful APIs</li>
        </ul>
      </div>

      <!-- Web Design -->
      <div class="group glass rounded-2xl p-8 border border-gray-800 hover:border-accent-primary/50 transition-all duration-300 hover:shadow-xl hover:shadow-accent-primary/10 animate-scale-in" style="animation-delay: 0.2s;">
        <div class="w-14 h-14 bg-accent-primary/10 rounded-lg flex items-center justify-center mb-6 group-hover:bg-accent-primary/20 transition-colors">
          <svg class="w-7 h-7 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-3">UI/UX Elegante</h3>
        <p class="text-gray-400 font-light mb-4 leading-relaxed">
          Interfaces limpias e intuitivas con enfoque en accesibilidad y experiencia del usuario
        </p>
        <ul class="space-y-2">
          <li class="text-sm text-gray-500 font-light">✦ Diseño responsivo</li>
          <li class="text-sm text-gray-500 font-light">✦ UX enfocada</li>
          <li class="text-sm text-gray-500 font-light">✦ Animaciones fluidas</li>
        </ul>
      </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <div class="glass rounded-xl p-6 border border-gray-800 text-center animate-fade-in" style="animation-delay: 0s;">
        <div class="text-3xl font-bold text-accent-primary mb-2">50+</div>
        <p class="text-gray-400 font-light">Proyectos completados</p>
      </div>
      <div class="glass rounded-xl p-6 border border-gray-800 text-center animate-fade-in" style="animation-delay: 0.1s;">
        <div class="text-3xl font-bold text-accent-primary mb-2">30+</div>
        <p class="text-gray-400 font-light">Clientes satisfechos</p>
      </div>
      <div class="glass rounded-xl p-6 border border-gray-800 text-center animate-fade-in" style="animation-delay: 0.2s;">
        <div class="text-3xl font-bold text-accent-primary mb-2">3+</div>
        <p class="text-gray-400 font-light">Años de experiencia</p>
      </div>
      <div class="glass rounded-xl p-6 border border-gray-800 text-center animate-fade-in" style="animation-delay: 0.3s;">
        <div class="text-3xl font-bold text-accent-primary mb-2">100%</div>
        <p class="text-gray-400 font-light">Dedicación total</p>
      </div>
    </div>
  </div>
</section>
