---
---

<section id="especialidades" class="py-32 px-6 bg-black relative overflow-hidden">

  <div class="max-w-6xl mx-auto relative z-10">
    <!-- Header -->
    <div class="mb-20 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Mis Especialidades
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto font-light hover:text-gray-300 transition-colors duration-300">
        Más de 3 años trabajando con tecnologías modernas para crear soluciones web escalables y eficientes
      </p>
    </div>

    <!-- 3 Specialty Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      <!-- Frontend Development -->
      <div class="group bg-white/5 rounded-xl p-8 border border-gray-800 hover:border-accent-primary/50 transition-all duration-300 hover:shadow-lg hover:shadow-accent-primary/10">
        <h3 class="text-2xl font-bold text-white mb-3">Frontend Moderno</h3>
        <p class="text-gray-400 font-light mb-4 leading-relaxed group-hover:text-gray-300 transition-colors duration-300">
          Diseño responsivo y experiencias de usuario excepcionales con React, Astro y Tailwind CSS
        </p>
        <ul class="space-y-2">
          <li class="text-sm text-gray-500 font-light group-hover:text-gray-400 transition-colors duration-300">✦ React & Next.js</li>
          <li class="text-sm text-gray-500 font-light group-hover:text-gray-400 transition-colors duration-300">✦ Astro Framework</li>
          <li class="text-sm text-gray-500 font-light group-hover:text-gray-400 transition-colors duration-300">✦ Tailwind CSS</li>
        </ul>
      </div>

      <!-- Backend Development -->
      <div class="group bg-white/5 rounded-xl p-8 border border-gray-800 hover:border-accent-primary/50 transition-all duration-300 hover:shadow-lg hover:shadow-accent-primary/10">
        <h3 class="text-2xl font-bold text-white mb-3">Backend Robusto</h3>
        <p class="text-gray-400 font-light mb-4 leading-relaxed group-hover:text-gray-300 transition-colors duration-300">
          APIs escalables y bases de datos eficientes con Node.js, Express y tecnologías cloud
        </p>
        <ul class="space-y-2">
          <li class="text-sm text-gray-500 font-light group-hover:text-gray-400 transition-colors duration-300">✦ Node.js & Express</li>
          <li class="text-sm text-gray-500 font-light group-hover:text-gray-400 transition-colors duration-300">✦ MongoDB & SQL</li>
          <li class="text-sm text-gray-500 font-light group-hover:text-gray-400 transition-colors duration-300">✦ RESTful APIs</li>
        </ul>
      </div>

      <!-- Web Design -->
      <div class="group bg-white/5 rounded-xl p-8 border border-gray-800 hover:border-accent-primary/50 transition-all duration-300 hover:shadow-lg hover:shadow-accent-primary/10">
        <h3 class="text-2xl font-bold text-white mb-3">UI/UX Elegante</h3>
        <p class="text-gray-400 font-light mb-4 leading-relaxed group-hover:text-gray-300 transition-colors duration-300">
          Interfaces limpias e intuitivas con enfoque en accesibilidad y experiencia del usuario
        </p>
        <ul class="space-y-2">
          <li class="text-sm text-gray-500 font-light group-hover:text-gray-400 transition-colors duration-300">✦ Diseño responsivo</li>
          <li class="text-sm text-gray-500 font-light group-hover:text-gray-400 transition-colors duration-300">✦ UX enfocada</li>
          <li class="text-sm text-gray-500 font-light group-hover:text-gray-400 transition-colors duration-300">✦ Animaciones fluidas</li>
        </ul>
      </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <div class="bg-white/5 rounded-lg p-6 border border-gray-800 text-center hover:border-accent-primary/50 group transition-all duration-300">
        <div class="text-3xl font-bold text-accent-primary mb-2">50+</div>
        <p class="text-gray-400 font-light group-hover:text-gray-300 transition-colors duration-300">Proyectos completados</p>
      </div>
      <div class="bg-white/5 rounded-lg p-6 border border-gray-800 text-center hover:border-accent-primary/50 group transition-all duration-300">
        <div class="text-3xl font-bold text-accent-primary mb-2">30+</div>
        <p class="text-gray-400 font-light group-hover:text-gray-300 transition-colors duration-300">Clientes satisfechos</p>
      </div>
      <div class="bg-white/5 rounded-lg p-6 border border-gray-800 text-center hover:border-accent-primary/50 group transition-all duration-300">
        <div class="text-3xl font-bold text-accent-primary mb-2">3+</div>
        <p class="text-gray-400 font-light group-hover:text-gray-300 transition-colors duration-300">Años de experiencia</p>
      </div>
      <div class="bg-white/5 rounded-lg p-6 border border-gray-800 text-center hover:border-accent-primary/50 group transition-all duration-300">
        <div class="text-3xl font-bold text-accent-primary mb-2">100%</div>
        <p class="text-gray-400 font-light group-hover:text-gray-300 transition-colors duration-300">Dedicación total</p>
      </div>
    </div>
  </div>
</section>
