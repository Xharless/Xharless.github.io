<section id="especialidades" class="py-32 px-6 bg-black relative overflow-hidden">

  <div class="max-w-6xl mx-auto relative z-10">
    <!-- Header -->
    <div class="mb-20 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4 smooth-transition">
        Mis Especialidades
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto font-light smooth-transition hover:text-gray-300">
        Más de 3 años trabajando con tecnologías modernas para crear soluciones web escalables y eficientes
      </p>
    </div>

    <!-- 3 Specialty Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      <!-- Frontend Development -->
      <div class="group glass-premium rounded-2xl p-8 border border-gray-800 hover:border-accent-primary/50 smooth-transition hover:shadow-2xl hover:shadow-accent-primary/10 will-change-transform">
        <h3 class="text-2xl font-bold text-white mb-3 smooth-transition">Frontend Moderno</h3>
        <p class="text-gray-400 font-light mb-4 leading-relaxed smooth-transition group-hover:text-gray-300">
          Diseño responsivo y experiencias de usuario excepcionales con React, Astro y Tailwind CSS
        </p>
        <ul class="space-y-2">
          <li class="text-sm text-gray-500 font-light smooth-transition group-hover:text-gray-400">✦ React & Next.js</li>
          <li class="text-sm text-gray-500 font-light smooth-transition group-hover:text-gray-400">✦ Astro Framework</li>
          <li class="text-sm text-gray-500 font-light smooth-transition group-hover:text-gray-400">✦ Tailwind CSS</li>
        </ul>
      </div>

      <!-- Backend Development -->
      <div class="group glass-premium rounded-2xl p-8 border border-gray-800 hover:border-accent-primary/50 smooth-transition hover:shadow-2xl hover:shadow-accent-primary/10 will-change-transform">
        <h3 class="text-2xl font-bold text-white mb-3 smooth-transition">Backend Robusto</h3>
        <p class="text-gray-400 font-light mb-4 leading-relaxed smooth-transition group-hover:text-gray-300">
          APIs escalables y bases de datos eficientes con Node.js, Express y tecnologías cloud
        </p>
        <ul class="space-y-2">
          <li class="text-sm text-gray-500 font-light smooth-transition group-hover:text-gray-400">✦ Node.js & Express</li>
          <li class="text-sm text-gray-500 font-light smooth-transition group-hover:text-gray-400">✦ MongoDB & SQL</li>
          <li class="text-sm text-gray-500 font-light smooth-transition group-hover:text-gray-400">✦ RESTful APIs</li>
        </ul>
      </div>

      <!-- Web Design -->
      <div class="group glass-premium rounded-2xl p-8 border border-gray-800 hover:border-accent-primary/50 smooth-transition hover:shadow-2xl hover:shadow-accent-primary/10 will-change-transform">
        <h3 class="text-2xl font-bold text-white mb-3 smooth-transition">UI/UX Elegante</h3>
        <p class="text-gray-400 font-light mb-4 leading-relaxed smooth-transition group-hover:text-gray-300">
          Interfaces limpias e intuitivas con enfoque en accesibilidad y experiencia del usuario
        </p>
        <ul class="space-y-2">
          <li class="text-sm text-gray-500 font-light smooth-transition group-hover:text-gray-400">✦ Diseño responsivo</li>
          <li class="text-sm text-gray-500 font-light smooth-transition group-hover:text-gray-400">✦ UX enfocada</li>
          <li class="text-sm text-gray-500 font-light smooth-transition group-hover:text-gray-400">✦ Animaciones fluidas</li>
        </ul>
      </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <div class="glass-premium rounded-xl p-6 border border-gray-800 text-center smooth-transition hover:border-accent-primary/50 group">
        <div class="text-3xl font-bold text-accent-primary mb-2 smooth-transition">50+</div>
        <p class="text-gray-400 font-light smooth-transition group-hover:text-gray-300">Proyectos completados</p>
      </div>
      <div class="glass-premium rounded-xl p-6 border border-gray-800 text-center smooth-transition hover:border-accent-primary/50 group">
        <div class="text-3xl font-bold text-accent-primary mb-2 smooth-transition">30+</div>
        <p class="text-gray-400 font-light smooth-transition group-hover:text-gray-300">Clientes satisfechos</p>
      </div>
      <div class="glass-premium rounded-xl p-6 border border-gray-800 text-center smooth-transition hover:border-accent-primary/50 group">
        <div class="text-3xl font-bold text-accent-primary mb-2 smooth-transition">3+</div>
        <p class="text-gray-400 font-light smooth-transition group-hover:text-gray-300">Años de experiencia</p>
      </div>
      <div class="glass-premium rounded-xl p-6 border border-gray-800 text-center smooth-transition hover:border-accent-primary/50 group">
        <div class="text-3xl font-bold text-accent-primary mb-2 smooth-transition">100%</div>
        <p class="text-gray-400 font-light smooth-transition group-hover:text-gray-300">Dedicación total</p>
      </div>
    </div>
  </div>
</section>
