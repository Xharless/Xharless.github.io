---
---

<section id="contacto" class="py-32 px-6 bg-black relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-accent-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-accent-secondary/5 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-6xl mx-auto relative z-10">
    <!-- Header -->
    <div class="mb-20 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Hablemos
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto font-light">
        ¿Tienes un proyecto en mente? Me encantaría colaborar contigo en tu próxima idea
      </p>
    </div>

    <!-- Contact Options Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      <!-- Email Card -->
      <a href="mailto:carlos@example.com" class="group glass rounded-2xl p-8 border border-gray-800 hover:border-accent-primary/50 transition-all duration-300 hover:shadow-2xl hover:shadow-accent-primary/10 animate-scale-in" style="animation-delay: 0s;">
        <div class="w-14 h-14 bg-accent-primary/10 rounded-lg flex items-center justify-center mb-6 group-hover:bg-accent-primary/20 transition-colors">
          <svg class="w-7 h-7 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">Email</h3>
        <p class="text-gray-400 font-light mb-4">carlos@example.com</p>
        <span class="text-accent-primary font-semibold group-hover:translate-x-1 transition-transform inline-flex items-center gap-2">
          Enviar →
        </span>
      </a>

      <!-- Phone Card -->
      <a href="tel:+56912345678" class="group glass rounded-2xl p-8 border border-gray-800 hover:border-accent-primary/50 transition-all duration-300 hover:shadow-2xl hover:shadow-accent-primary/10 animate-scale-in" style="animation-delay: 0.1s;">
        <div class="w-14 h-14 bg-accent-primary/10 rounded-lg flex items-center justify-center mb-6 group-hover:bg-accent-primary/20 transition-colors">
          <svg class="w-7 h-7 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">Teléfono</h3>
        <p class="text-gray-400 font-light mb-4">+56 9 1234 5678</p>
        <span class="text-accent-primary font-semibold group-hover:translate-x-1 transition-transform inline-flex items-center gap-2">
          Llamar →
        </span>
      </a>

      <!-- Location Card -->
      <div class="group glass rounded-2xl p-8 border border-gray-800 hover:border-accent-primary/50 transition-all duration-300 hover:shadow-2xl hover:shadow-accent-primary/10 animate-scale-in" style="animation-delay: 0.2s;">
        <div class="w-14 h-14 bg-accent-primary/10 rounded-lg flex items-center justify-center mb-6 group-hover:bg-accent-primary/20 transition-colors">
          <svg class="w-7 h-7 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">Ubicación</h3>
        <p class="text-gray-400 font-light mb-4">Santiago, Chile</p>
        <span class="text-accent-primary font-semibold inline-flex items-center gap-2">
          Conectemos →
        </span>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="max-w-2xl mx-auto">
      <form id="contactForm" class="glass rounded-2xl p-10 border border-gray-800 backdrop-blur-md">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
          <div class="animate-slide-up" style="animation-delay: 0s;">
            <label class="block text-white font-semibold mb-3 text-sm">Tu Nombre</label>
            <input type="text" required placeholder="Juan Pérez" class="w-full px-4 py-3 bg-white/5 border border-gray-800 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-accent-primary focus:bg-white/10 transition-all duration-300"/>
          </div>
          <div class="animate-slide-up" style="animation-delay: 0.1s;">
            <label class="block text-white font-semibold mb-3 text-sm">Tu Email</label>
            <input type="email" required placeholder="tu@email.com" class="w-full px-4 py-3 bg-white/5 border border-gray-800 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-accent-primary focus:bg-white/10 transition-all duration-300"/>
          </div>
        </div>

        <div class="mb-6 animate-slide-up" style="animation-delay: 0.2s;">
          <label class="block text-white font-semibold mb-3 text-sm">Asunto</label>
          <input type="text" required placeholder="¿Sobre qué es?" class="w-full px-4 py-3 bg-white/5 border border-gray-800 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-accent-primary focus:bg-white/10 transition-all duration-300"/>
        </div>

        <div class="mb-8 animate-slide-up" style="animation-delay: 0.3s;">
          <label class="block text-white font-semibold mb-3 text-sm">Mensaje</label>
          <textarea required rows="6" placeholder="Cuéntame tu idea..." class="w-full px-4 py-3 bg-white/5 border border-gray-800 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-accent-primary focus:bg-white/10 transition-all duration-300 resize-none"></textarea>
        </div>

        <button type="submit" class="w-full px-8 py-4 bg-accent-primary text-black rounded-lg font-semibold hover:bg-accent-primary/90 transition-all duration-300 transform hover:scale-105 shadow-xl shadow-accent-primary/30 animate-slide-up" style="animation-delay: 0.4s;">
          Enviar Mensaje
        </button>
      </form>
    </div>

    <!-- Social Links -->
    <div class="flex justify-center gap-4 mt-20 animate-slide-up" style="animation-delay: 0.5s;">
      <a href="https://github.com/Xharless" target="_blank" rel="noopener noreferrer" class="w-12 h-12 glass rounded-lg border border-gray-800 flex items-center justify-center hover:border-accent-primary hover:bg-accent-primary/10 transition-all transform hover:scale-110">
        <svg class="w-6 h-6 text-gray-400 hover:text-accent-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
      <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="w-12 h-12 glass rounded-lg border border-gray-800 flex items-center justify-center hover:border-accent-primary hover:bg-accent-primary/10 transition-all transform hover:scale-110">
        <svg class="w-6 h-6 text-gray-400 hover:text-accent-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
      </a>
      <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="w-12 h-12 glass rounded-lg border border-gray-800 flex items-center justify-center hover:border-accent-primary hover:bg-accent-primary/10 transition-all transform hover:scale-110">
        <svg class="w-6 h-6 text-gray-400 hover:text-accent-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 002.856-3.51 9.95 9.95 0 01-2.8.856 4.958 4.958 0 002.165-2.724c-.951.564-2.005.974-3.127 1.195a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417a9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
      </a>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contactForm');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      alert('¡Gracias por tu mensaje! Me pondré en contacto pronto');
      form.reset();
    });
  }
</script>
