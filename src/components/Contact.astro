---
---

<section id="contacto" class="py-32 px-6 bg-black relative overflow-hidden">
  <div class=\"max-w-6xl mx-auto relative z-10\">
    <!-- Header -->
    <div class="mb-20 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4 smooth-transition">
        Hablemos
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto font-light smooth-transition hover:text-gray-300">
        ¿Tienes un proyecto en mente? Me encantaría colaborar contigo en tu próxima idea
      </p>
    </div>

    <!-- Contact Options Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      <!-- Email Card -->
      <a href="mailto:carlos@example.com" class="group glass-premium rounded-2xl p-8 border border-gray-800 hover:border-accent-primary/50 smooth-transition will-change-transform hover:shadow-2xl hover:shadow-accent-primary/20">
        <h3 class="text-xl font-bold text-white mb-2 smooth-transition">Email</h3>
        <p class="text-gray-400 font-light mb-4 smooth-transition group-hover:text-gray-300">carlos@example.com</p>
        <span class="text-accent-primary font-semibold group-hover:translate-x-1 smooth-fast inline-flex items-center gap-2">
          Enviar →
        </span>
      </a>

      <!-- Phone Card -->
      <a href="tel:+56912345678" class="group glass-premium rounded-2xl p-8 border border-gray-800 hover:border-accent-primary/50 smooth-transition will-change-transform hover:shadow-2xl hover:shadow-accent-primary/20">
        <h3 class="text-xl font-bold text-white mb-2 smooth-transition">Teléfono</h3>
        <p class="text-gray-400 font-light mb-4 smooth-transition group-hover:text-gray-300">+56 9 1234 5678</p>
        <span class="text-accent-primary font-semibold group-hover:translate-x-1 smooth-fast inline-flex items-center gap-2">
          Llamar →
        </span>
      </a>

      <!-- Location Card -->
      <div class="group glass-premium rounded-2xl p-8 border border-gray-800 hover:border-accent-primary/50 smooth-transition will-change-transform hover:shadow-2xl hover:shadow-accent-primary/20">
        <h3 class="text-xl font-bold text-white mb-2 smooth-transition">Ubicación</h3>
        <p class="text-gray-400 font-light mb-4 smooth-transition group-hover:text-gray-300">Santiago, Chile</p>
        <span class="text-accent-primary font-semibold inline-flex items-center gap-2">
          Conectemos →
        </span>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="max-w-2xl mx-auto">
      <form id="contactForm" class="glass-premium rounded-2xl p-10 border border-gray-800 backdrop-blur-md smooth-transition">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
          <div>
            <label class="block text-white font-semibold mb-3 text-sm smooth-transition">Tu Nombre</label>
            <input type="text" required placeholder="Juan Pérez" class="w-full px-4 py-3 bg-white/5 border border-gray-800 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-accent-primary focus:bg-white/10 smooth-transition"/>
          </div>
          <div>
            <label class="block text-white font-semibold mb-3 text-sm smooth-transition">Tu Email</label>
            <input type="email" required placeholder="tu@email.com" class="w-full px-4 py-3 bg-white/5 border border-gray-800 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-accent-primary focus:bg-white/10 smooth-transition"/>
          </div>
        </div>

        <div class="mb-6">
          <label class="block text-white font-semibold mb-3 text-sm smooth-transition">Asunto</label>
          <input type="text" required placeholder="¿Sobre qué es?" class="w-full px-4 py-3 bg-white/5 border border-gray-800 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-accent-primary focus:bg-white/10 smooth-transition"/>
        </div>

        <div class="mb-8">
          <label class="block text-white font-semibold mb-3 text-sm smooth-transition">Mensaje</label>
          <textarea required rows="6" placeholder="Cuéntame tu idea..." class="w-full px-4 py-3 bg-white/5 border border-gray-800 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-accent-primary focus:bg-white/10 smooth-transition resize-none"></textarea>
        </div>

        <button type="submit" class="w-full px-8 py-4 bg-accent-primary text-black rounded-lg font-semibold hover:bg-accent-primary/90 smooth-transition will-change-transform shadow-xl shadow-accent-primary/30">
          Enviar Mensaje
        </button>
      </form>
    </div>

    <!-- Social Links -->
    <div class="flex justify-center gap-4 mt-20 smooth-transition">
      <a href="https://github.com/Xharless" target="_blank" rel="noopener noreferrer" class="w-12 h-12 glass-premium rounded-lg border border-gray-800 flex items-center justify-center hover:border-accent-primary hover:bg-accent-primary/10 smooth-transition will-change-transform">
        GitHub
      </a>
      <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="w-12 h-12 glass-premium rounded-lg border border-gray-800 flex items-center justify-center hover:border-accent-primary hover:bg-accent-primary/10 smooth-transition will-change-transform">
        LinkedIn
      </a>
      <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="w-12 h-12 glass-premium rounded-lg border border-gray-800 flex items-center justify-center hover:border-accent-primary hover:bg-accent-primary/10 smooth-transition will-change-transform">
        Twitter
      </a>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contactForm');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      alert('¡Gracias por tu mensaje! Me pondré en contacto pronto');
      form.reset();
    });
  }
</script>
