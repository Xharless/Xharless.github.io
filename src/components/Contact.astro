---
---

<section id="contacto" class="py-24 bg-black/50 relative overflow-hidden">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-accent-primary rounded-full mix-blend-multiply filter blur-3xl opacity-5"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-accent-secondary rounded-full mix-blend-multiply filter blur-3xl opacity-5"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="mb-16 text-center animate-slide-up">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Ponte en Contacto</h2>
      <p class="text-gray-400 text-lg">¿Tienes un proyecto? Me encantaría conversar</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      <div class="group relative glass rounded-2xl p-6 border border-dark-700 hover:border-accent-primary/50 transition-all duration-500 hover:shadow-2xl hover:shadow-accent-primary/10 animate-scale-in" style="animation-delay: 0s;">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl"></div>
        <div class="relative z-10">
          <div class="w-12 h-12 bg-accent-primary/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent-primary/20 transition-colors">
            <svg class="w-6 h-6 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">Email</h3>
          <p class="text-gray-400 text-sm mb-4">tu@email.com</p>
          <a href="mailto:tu@email.com" class="text-accent-primary hover:text-accent-secondary transition-colors text-sm font-semibold">Enviar →</a>
        </div>
      </div>

      <div class="group relative glass rounded-2xl p-6 border border-dark-700 hover:border-accent-primary/50 transition-all duration-500 hover:shadow-2xl hover:shadow-accent-primary/10 animate-scale-in" style="animation-delay: 0.1s;">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl"></div>
        <div class="relative z-10">
          <div class="w-12 h-12 bg-accent-primary/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent-primary/20 transition-colors">
            <svg class="w-6 h-6 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">Teléfono</h3>
          <p class="text-gray-400 text-sm mb-4">+56 9 XXXX XXXX</p>
          <a href="tel:+56912345678" class="text-accent-primary hover:text-accent-secondary transition-colors text-sm font-semibold">Llamar →</a>
        </div>
      </div>

      <div class="group relative glass rounded-2xl p-6 border border-dark-700 hover:border-accent-primary/50 transition-all duration-500 hover:shadow-2xl hover:shadow-accent-primary/10 animate-scale-in" style="animation-delay: 0.2s;">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl"></div>
        <div class="relative z-10">
          <div class="w-12 h-12 bg-accent-primary/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-accent-primary/20 transition-colors">
            <svg class="w-6 h-6 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">Ubicación</h3>
          <p class="text-gray-400 text-sm mb-4">Chile</p>
          <a href="#" class="text-accent-primary hover:text-accent-secondary transition-colors text-sm font-semibold">Ubicación →</a>
        </div>
      </div>
    </div>

    <div class="max-w-2xl mx-auto">
      <form id="contactForm" class="glass rounded-2xl p-8 border border-dark-700 backdrop-blur-md">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
          <div class="animate-slide-up" style="animation-delay: 0s;">
            <label class="block text-gray-300 font-semibold mb-2 text-sm">Nombre</label>
            <input type="text" required class="w-full px-4 py-2 bg-white/5 border border-dark-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-accent-primary focus:bg-white/10 transition-all duration-300"/>
          </div>
          <div class="animate-slide-up" style="animation-delay: 0.1s;">
            <label class="block text-gray-300 font-semibold mb-2 text-sm">Email</label>
            <input type="email" required class="w-full px-4 py-2 bg-white/5 border border-dark-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-accent-primary focus:bg-white/10 transition-all duration-300"/>
          </div>
        </div>

        <div class="mb-6 animate-slide-up" style="animation-delay: 0.2s;">
          <label class="block text-gray-300 font-semibold mb-2 text-sm">Asunto</label>
          <input type="text" required class="w-full px-4 py-2 bg-white/5 border border-dark-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-accent-primary focus:bg-white/10 transition-all duration-300"/>
        </div>

        <div class="mb-8 animate-slide-up" style="animation-delay: 0.3s;">
          <label class="block text-gray-300 font-semibold mb-2 text-sm">Mensaje</label>
          <textarea required rows="5" class="w-full px-4 py-2 bg-white/5 border border-dark-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-accent-primary focus:bg-white/10 transition-all duration-300 resize-none"></textarea>
        </div>

        <button type="submit" class="w-full px-8 py-3 bg-accent-primary text-black rounded-lg font-semibold hover:bg-accent-primary/90 transition-all duration-300 transform hover:scale-105 animate-slide-up shadow-lg shadow-accent-primary/30" style="animation-delay: 0.4s;">
          Enviar Mensaje
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contactForm');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      alert('¡Gracias por tu mensaje! Me pondré en contacto pronto');
      form.reset();
    });
  }
</script>
