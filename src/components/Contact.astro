---
---

<section id="contacto" class="py-20 bg-gradient-to-br from-dark via-dark-secondary to-dark relative overflow-hidden">
  <!-- Elementos decorativos -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-indigo-600 rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
    <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-pink-600 rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="mb-12 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Ponte en Contacto</h2>
      <p class="text-slate-400 text-lg">¿Tienes un proyecto en mente? Me encantaría hablar contigo</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
      <!-- Contact Info 1 -->
      <div class="group p-8 bg-white/5 backdrop-blur-lg border border-white/10 rounded-xl hover:border-indigo-500/50 transition-all duration-300 hover:bg-white/10">
        <div class="w-14 h-14 bg-gradient-to-br from-indigo-600 to-pink-600 rounded-lg flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-white mb-2">Email</h3>
        <p class="text-slate-300">tu@email.com</p>
        <a href="mailto:tu@email.com" class="inline-flex items-center text-indigo-400 hover:text-pink-400 transition-colors mt-4 text-sm font-semibold">
          Enviar Email
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <!-- Contact Info 2 -->
      <div class="group p-8 bg-white/5 backdrop-blur-lg border border-white/10 rounded-xl hover:border-indigo-500/50 transition-all duration-300 hover:bg-white/10">
        <div class="w-14 h-14 bg-gradient-to-br from-indigo-600 to-pink-600 rounded-lg flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-white mb-2">Teléfono</h3>
        <p class="text-slate-300">+56 9 XXXX XXXX</p>
        <a href="tel:+56912345678" class="inline-flex items-center text-indigo-400 hover:text-pink-400 transition-colors mt-4 text-sm font-semibold">
          Llamar
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <!-- Contact Info 3 -->
      <div class="group p-8 bg-white/5 backdrop-blur-lg border border-white/10 rounded-xl hover:border-indigo-500/50 transition-all duration-300 hover:bg-white/10">
        <div class="w-14 h-14 bg-gradient-to-br from-indigo-600 to-pink-600 rounded-lg flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-white mb-2">Ubicación</h3>
        <p class="text-slate-300">Chile</p>
        <a href="#" class="inline-flex items-center text-indigo-400 hover:text-pink-400 transition-colors mt-4 text-sm font-semibold">
          Ver Ubicación
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="max-w-2xl mx-auto">
      <form id="contactForm" class="bg-white/5 backdrop-blur-lg border border-white/10 rounded-2xl p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
          <div>
            <label for="name" class="block text-white font-semibold mb-2">Nombre</label>
            <input 
              type="text" 
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-slate-400 focus:outline-none focus:border-indigo-500/50 focus:bg-white/20 transition-all duration-300"
              placeholder="Tu nombre"
            >
          </div>
          <div>
            <label for="email" class="block text-white font-semibold mb-2">Email</label>
            <input 
              type="email" 
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-slate-400 focus:outline-none focus:border-indigo-500/50 focus:bg-white/20 transition-all duration-300"
              placeholder="tu@email.com"
            >
          </div>
        </div>

        <div class="mb-6">
          <label for="subject" class="block text-white font-semibold mb-2">Asunto</label>
          <input 
            type="text" 
            id="subject"
            name="subject"
            required
            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-slate-400 focus:outline-none focus:border-indigo-500/50 focus:bg-white/20 transition-all duration-300"
            placeholder="Asunto de tu mensaje"
          >
        </div>

        <div class="mb-8">
          <label for="message" class="block text-white font-semibold mb-2">Mensaje</label>
          <textarea 
            id="message"
            name="message"
            rows="5"
            required
            class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder-slate-400 focus:outline-none focus:border-indigo-500/50 focus:bg-white/20 transition-all duration-300 resize-none"
            placeholder="Tu mensaje aquí..."
          ></textarea>
        </div>

        <button 
          type="submit"
          class="w-full px-8 py-4 bg-gradient-to-r from-indigo-600 to-pink-600 text-white rounded-lg font-semibold hover:shadow-xl hover:shadow-indigo-600/50 transition-all duration-300 transform hover:-translate-y-1"
        >
          Enviar Mensaje
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contactForm');
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      // Aquí iría la lógica para enviar el formulario
      alert('Gracias por tu mensaje. Me pondré en contacto pronto.');
      form.reset();
    });
  }
</script>
