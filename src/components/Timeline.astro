---
const timeline = [
  {
    year: "2025",
    role: "Desarrollador Full-Stack Senior",
    company: "Freelance & Consultoría",
    description:
      "Diseño y desarrollo de aplicaciones web completas para clientes de distintas industrias. Especialización en arquitectura frontend moderna y optimización de rendimiento.",
    tags: ["Next.js", "TypeScript", "AWS", "Prisma"],
    type: "work",
    current: true,
  },
  {
    year: "2024",
    role: "Desarrollador Frontend",
    company: "Startup SaaS — Remoto",
    description:
      "Construcción del dashboard principal de la plataforma desde cero. Implementación de sistema de diseño, autenticación y visualizaciones de datos en tiempo real.",
    tags: ["React", "Tailwind", "GraphQL", "Figma"],
    type: "work",
    current: false,
  },
  {
    year: "2023",
    role: "Certificación Cloud & DevOps",
    company: "AWS + Docker",
    description:
      "Formación intensiva en infraestructura cloud, contenedores y pipelines de CI/CD. Aplicación directa en proyectos de producción.",
    tags: ["AWS", "Docker", "GitHub Actions", "Terraform"],
    type: "education",
    current: false,
  },
  {
    year: "2022",
    role: "Desarrollador Web Junior",
    company: "Agencia Digital",
    description:
      "Primer rol profesional. Desarrollo de sitios y e-commerce para clientes locales. Aprendizaje acelerado de buenas prácticas, Git y trabajo en equipo.",
    tags: ["React", "Node.js", "MySQL", "WordPress"],
    type: "work",
    current: false,
  },
  {
    year: "2021",
    role: "Ingeniería en Informática",
    company: "Universidad — Chile",
    description:
      "Formación en ciencias de la computación, algoritmos, bases de datos y desarrollo de software. Proyectos de título enfocados en aplicaciones web.",
    tags: ["Algoritmos", "POO", "SQL", "Linux"],
    type: "education",
    current: false,
  },
];
---

<section id="experiencia" class="relative py-32 px-6 overflow-hidden">
  <div class="max-w-4xl mx-auto">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-amber-500/30 bg-amber-500/10 text-amber-300 text-xs font-semibold tracking-wider uppercase mb-6 reveal delay-100">
      <span class="w-2 h-2 rounded-full bg-amber-500"></span>
      Experiencia
    </div>
    
    <h2 class="text-4xl md:text-5xl font-display font-bold tracking-tight text-white mb-4 reveal delay-200">
      Mi trayectoria.
    </h2>
    <p class="text-zinc-400 text-lg leading-relaxed font-light mb-20 reveal delay-300">
      El camino que me trajo hasta aquí.
    </p>

    <div class="relative flex flex-col">
      <!-- Vertical line -->
      <div class="absolute left-[39px] sm:left-[119px] top-6 bottom-6 w-[2px] bg-white/10 rounded-full overflow-hidden">
        <div id="timelineFill" class="absolute top-0 left-0 w-full bg-gradient-to-b from-amber-400 to-fuchsia-500 h-0 transition-all duration-300 shadow-[0_0_15px_rgba(251,191,36,0.5)]"></div>
      </div>

      {timeline.map((item, i) => (
        <div class="relative grid grid-cols-[80px_1fr] sm:grid-cols-[120px_1fr] gap-4 sm:gap-10 py-6 items-start reveal delay-100 group">
          
          <!-- Node -->
          <div class="flex flex-col sm:items-end items-center pt-5 relative z-10">
            <div class={`w-12 h-12 rounded-full flex items-center justify-center border-2 bg-[#0a0a0a] transition-all duration-300 ${
              item.current 
                ? "border-amber-400 text-amber-400 shadow-[0_0_15px_rgba(251,191,36,0.3)] group-hover:scale-110" 
                : item.type === 'work'
                  ? "border-white/20 text-zinc-400 group-hover:border-amber-400/50 group-hover:text-amber-400"
                  : "border-white/20 text-zinc-400 group-hover:border-fuchsia-400/50 group-hover:text-fuchsia-400"
            }`}>
              {item.type === "work" ? (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
              ) : (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m4 6 8-4 8 4"/><path d="m18 10 4 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-8l4-2"/><path d="M14 22v-4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v4"/><path d="M18 5v17"/><path d="M6 5v17"/><circle cx="12" cy="9" r="2"/></svg>
              )}
            </div>
            <div class="hidden sm:block mt-2 font-display font-bold text-sm tracking-widest text-zinc-500 group-hover:text-zinc-300 transition-colors">
              {item.year}
            </div>
          </div>

          <!-- Card -->
          <div class={`rounded-2xl bg-[#0a0a0a]/80 backdrop-blur-md border transition-all duration-300 p-6 sm:p-8 ${
            item.current ? "border-amber-500/30 hover:border-amber-500/60 shadow-[0_4px_30px_rgba(251,191,36,0.05)]" : "border-white/10 hover:border-white/20 hover:bg-white/5"
          }`}>
            <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-4">
              <div>
                <h3 class="text-xl font-display font-bold text-white mb-1 group-hover:text-amber-300 transition-colors">{item.role}</h3>
                <div class="text-zinc-400 font-medium">{item.company}</div>
                <div class="sm:hidden mt-1 text-sm font-bold text-zinc-500 tracking-widest">{item.year}</div>
              </div>
              <div class="flex flex-wrap gap-2">
                {item.current && (
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-amber-500/30 bg-amber-500/10 text-amber-300 text-xs font-semibold uppercase tracking-wider">
                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>
                    Actual
                  </span>
                )}
                <span class={`inline-flex items-center px-3 py-1 rounded-full border text-xs font-semibold uppercase tracking-wider ${
                  item.type === 'work' 
                    ? "border-blue-500/20 bg-blue-500/10 text-blue-300"
                    : "border-fuchsia-500/20 bg-fuchsia-500/10 text-fuchsia-300"
                }`}>
                  {item.type === "work" ? "Trabajo" : "Formación"}
                </span>
              </div>
            </div>

            <p class="text-zinc-400 leading-relaxed font-light mb-6">
              {item.description}
            </p>

            <div class="flex flex-wrap gap-2">
              {item.tags.map((tag) => (
                <span class="px-3 py-1 text-xs font-medium text-zinc-300 bg-white/5 border border-white/10 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
          </div>

        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Animate timeline line on scroll
  const section = document.querySelector("#experiencia") as HTMLElement;
  const fill = document.getElementById("timelineFill");

  if (section && fill) {
    function updateLine() {
      const rect = section.getBoundingClientRect();
      const windowH = window.innerHeight;
      const sectionH = section.offsetHeight;

      // How far we've scrolled into the section
      const scrolled = Math.max(0, windowH - rect.top);
      const progress = Math.min(scrolled / (sectionH + windowH * 0.5), 1);

      fill!.style.height = (progress * 100) + "%";
    }

    window.addEventListener("scroll", updateLine, { passive: true });
    updateLine();
  }
</script>
