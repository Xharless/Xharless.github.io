---
---

<section id="proyectos" class="py-24 bg-black/50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="mb-16 animate-slide-up">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Proyectos</h2>
      <div class="w-20 h-1 bg-gradient-to-r from-accent-primary to-accent-secondary rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="group relative glass rounded-2xl overflow-hidden border border-dark-700 hover:border-accent-primary/50 transition-all duration-500 cursor-pointer animate-scale-in hover:shadow-2xl hover:shadow-accent-primary/10" style="animation-delay: 0s;">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="h-40 bg-gradient-to-br from-accent-primary/20 to-accent-secondary/20 border-b border-dark-700 flex items-center justify-center overflow-hidden relative">
          <span class="text-5xl group-hover:scale-120 transition-transform duration-300 z-10">💼</span>
        </div>
        <div class="p-6 relative z-10">
          <h3 class="text-lg font-semibold mb-2 text-white">Plataforma SaaS</h3>
          <p class="text-gray-400 text-sm mb-4">Gestión de proyectos con autenticación y panel en tiempo real.</p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-3 py-1 bg-accent-primary/10 text-accent-primary text-xs font-semibold rounded-full border border-accent-primary/20">React</span>
            <span class="px-3 py-1 bg-accent-primary/10 text-accent-primary text-xs font-semibold rounded-full border border-accent-primary/20">Node.js</span>
          </div>
          <a href="#" class="inline-flex items-center text-accent-primary hover:text-accent-secondary transition-colors group/link text-sm font-semibold">
            Explorar
            <svg class="w-4 h-4 ml-2 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="group relative glass rounded-2xl overflow-hidden border border-dark-700 hover:border-accent-primary/50 transition-all duration-500 cursor-pointer animate-scale-in hover:shadow-2xl hover:shadow-accent-primary/10" style="animation-delay: 0.1s;">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="h-40 bg-gradient-to-br from-accent-primary/20 to-accent-secondary/20 border-b border-dark-700 flex items-center justify-center overflow-hidden relative">
          <span class="text-5xl group-hover:scale-120 transition-transform duration-300 z-10">🎨</span>
        </div>
        <div class="p-6 relative z-10">
          <h3 class="text-lg font-semibold mb-2 text-white">Portafolio Web</h3>
          <p class="text-gray-400 text-sm mb-4">Sitio responsivo con diseño moderno y animaciones.</p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-3 py-1 bg-accent-primary/10 text-accent-primary text-xs font-semibold rounded-full border border-accent-primary/20">Astro</span>
            <span class="px-3 py-1 bg-accent-primary/10 text-accent-primary text-xs font-semibold rounded-full border border-accent-primary/20">Tailwind</span>
          </div>
          <a href="#" class="inline-flex items-center text-accent-primary hover:text-accent-secondary transition-colors group/link text-sm font-semibold">
            Explorar
            <svg class="w-4 h-4 ml-2 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="group relative glass rounded-2xl overflow-hidden border border-dark-700 hover:border-accent-primary/50 transition-all duration-500 cursor-pointer animate-scale-in hover:shadow-2xl hover:shadow-accent-primary/10" style="animation-delay: 0.2s;">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="h-40 bg-gradient-to-br from-accent-primary/20 to-accent-secondary/20 border-b border-dark-700 flex items-center justify-center overflow-hidden relative">
          <span class="text-5xl group-hover:scale-120 transition-transform duration-300 z-10">📱</span>
        </div>
        <div class="p-6 relative z-10">
          <h3 class="text-lg font-semibold mb-2 text-white">App Móvil</h3>
          <p class="text-gray-400 text-sm mb-4">Aplicación nativa con sincronización en la nube.</p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-3 py-1 bg-accent-primary/10 text-accent-primary text-xs font-semibold rounded-full border border-accent-primary/20">React Native</span>
            <span class="px-3 py-1 bg-accent-primary/10 text-accent-primary text-xs font-semibold rounded-full border border-accent-primary/20">Firebase</span>
          </div>
          <a href="#" class="inline-flex items-center text-accent-primary hover:text-accent-secondary transition-colors group/link text-sm font-semibold">
            Explorar
            <svg class="w-4 h-4 ml-2 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 text-center animate-slide-up" style="animation-delay: 0.3s;">
      <a href="#proyectos" class="inline-flex items-center px-8 py-3 bg-accent-primary text-black rounded-lg font-semibold hover:bg-accent-primary/90 transition-all duration-300 transform hover:scale-105 shadow-lg shadow-accent-primary/30">
        Ver Más Proyectos
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
