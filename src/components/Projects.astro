---
const svgBarChart = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400"><line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/></svg>`;
const svgShoppingBag = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-fuchsia-400"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>`;
const svgCheckCircle = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-400"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>`;
const svgBot = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>`;
const svgFileText = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-rose-400"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><line x1="10" x2="8" y1="9" y2="9"/></svg>`;
const svgCloudSun = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-400"><path d="M12 2v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="M20 12h2"/><path d="m19.07 4.93-1.41 1.41"/><path d="M15.947 12.65a4 4 0 0 0-5.925-4.128"/><path d="M13 22H7a5 5 0 1 1 4.9-6H13a3 3 0 0 1 0 6Z"/></svg>`;

const projects = [
  {
    title: "Dashboard Analytics",
    description: "Plataforma de análisis de datos en tiempo real con visualizaciones interactivas, filtros avanzados y exportación de reportes.",
    tags: ["React", "TypeScript", "D3.js", "Node.js"],
    glow: "from-blue-500/20 to-cyan-500/20",
    borderHover: "hover:border-blue-500/50",
    icon: svgBarChart,
    github: "https://github.com",
    demo: "https://demo.com",
    featured: true,
  },
  {
    title: "E-commerce Platform",
    description: "Tienda online con carrito, pagos integrados con Stripe, panel de administración y optimización SEO avanzada.",
    tags: ["Next.js", "Prisma", "PostgreSQL", "Stripe"],
    glow: "from-fuchsia-500/20 to-purple-500/20",
    borderHover: "hover:border-fuchsia-500/50",
    icon: svgShoppingBag,
    github: "https://github.com",
    demo: "https://demo.com",
    featured: true,
  },
  {
    title: "Task Management App",
    description: "Aplicación de gestión de tareas con drag & drop, colaboración en tiempo real y notificaciones push.",
    tags: ["React", "Socket.io", "Express", "MongoDB"],
    glow: "from-emerald-500/20 to-teal-500/20",
    borderHover: "hover:border-emerald-500/50",
    icon: svgCheckCircle,
    github: "https://github.com",
    demo: "https://demo.com",
    featured: false,
  },
  {
    title: "AI Chat Interface",
    description: "Interfaz de chat para modelos de lenguaje con streaming de respuestas, historial de conversaciones y temas personalizables.",
    tags: ["Astro", "OpenAI API", "Tailwind", "TypeScript"],
    glow: "from-amber-500/20 to-orange-500/20",
    borderHover: "hover:border-amber-500/50",
    icon: svgBot,
    github: "https://github.com",
    demo: "https://demo.com",
    featured: false,
  },
  {
    title: "Portfolio CMS",
    description: "Sistema de gestión de contenido headless para portafolios, con editor visual y despliegue automático.",
    tags: ["Astro", "Sanity", "Vercel", "TypeScript"],
    glow: "from-rose-500/20 to-pink-500/20",
    borderHover: "hover:border-rose-500/50",
    icon: svgFileText,
    github: "https://github.com",
    demo: "https://demo.com",
    featured: false,
  },
  {
    title: "Weather App",
    description: "Aplicación meteorológica con pronóstico de 7 días, geolocalización y visualización animada de condiciones.",
    tags: ["React", "OpenWeather API", "Framer Motion"],
    glow: "from-cyan-500/20 to-blue-500/20",
    borderHover: "hover:border-cyan-500/50",
    icon: svgCloudSun,
    github: "https://github.com",
    demo: "https://demo.com",
    featured: false,
  },
];
---

<section id="proyectos" class="relative py-32 px-6 overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6 reveal delay-100">
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-fuchsia-500/30 bg-fuchsia-500/10 text-fuchsia-300 text-xs font-semibold tracking-wider uppercase mb-6">
          <span class="w-2 h-2 rounded-full bg-fuchsia-500"></span>
          Portafolio
        </div>
        <h2 class="text-4xl md:text-5xl font-display font-bold tracking-tight text-white">
          Trabajo <span class="text-transparent bg-clip-text bg-gradient-to-r from-fuchsia-400 to-purple-500">Destacado</span>.
        </h2>
      </div>
      <a href="https://github.com" target="_blank" rel="noopener" class="group inline-flex items-center gap-2 text-fuchsia-400 font-semibold text-sm hover:text-fuchsia-300 transition-colors">
        Ver todos en GitHub
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="transition-transform group-hover:translate-x-1">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project, i) => (
        <div class={`group relative overflow-hidden rounded-2xl bg-[#0a0a0a]/80 backdrop-blur-md border border-white/10 p-8 transition-all duration-300 hover:-translate-y-2 reveal delay-${(i % 3 + 1) * 100} ${project.featured ? 'md:col-span-2 lg:col-span-2' : ''} ${project.borderHover}`}>
          <!-- Hover Glow -->
          <div class={`absolute inset-0 bg-gradient-to-br ${project.glow} opacity-0 group-hover:opacity-100 transition-opacity duration-500`}></div>
          
          <div class="relative z-10 h-full flex flex-col">
            <div class="flex items-center justify-between mb-6">
              <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-2xl shadow-xl group-hover:scale-110 transition-transform duration-300">
                <Fragment set:html={project.icon} />
              </div>
              {project.featured && (
                <span class="px-3 py-1 rounded-full border border-fuchsia-500/30 bg-fuchsia-500/10 text-fuchsia-300 text-xs font-semibold uppercase tracking-widest">
                  Destacado
                </span>
              )}
            </div>

            <h3 class="text-2xl font-display font-bold text-white mb-3">{project.title}</h3>
            <p class="text-zinc-400 font-light leading-relaxed mb-8 flex-1 group-hover:text-zinc-300 transition-colors">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-2 mb-8">
              {project.tags.map((tag) => (
                <span class="px-3 py-1 text-xs font-medium text-zinc-300 bg-white/5 border border-white/10 rounded-full">
                  {tag}
                </span>
              ))}
            </div>

            <div class="flex gap-4 mt-auto pt-6 border-t border-white/10">
              <a href={project.github} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm font-semibold text-zinc-300 hover:text-white transition-colors">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
                Código
              </a>
              <a href={project.demo} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm font-semibold text-fuchsia-400 hover:text-fuchsia-300 transition-colors">
                Live Demo
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
