---
---

<section id="proyectos" class="py-32 px-6 bg-black relative overflow-hidden">
  <div class="max-w-6xl mx-auto relative z-10">
    <!-- Header -->
    <div class="mb-20 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Proyectos Destacados
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto font-light hover:text-gray-300 transition-colors duration-300">
        Algunos de los proyectos más impactantes que he desarrollado con diferentes tecnologías
      </p>
    </div>

    <!-- Projects Featured Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-20">
      <!-- Project 1 - Featured Large -->
      <div class="group lg:col-span-1 bg-white/5 rounded-xl overflow-hidden border border-gray-800 hover:border-accent-primary/50 transition-all duration-300 hover:shadow-lg hover:shadow-accent-primary/20">
        <div class="h-56 bg-gradient-to-br from-accent-primary/30 to-accent-secondary/20 border-b border-gray-800 flex items-center justify-center overflow-hidden relative">
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
        </div>
        <div class="p-8 relative z-10">
          <div class="mb-4">
            <h3 class="text-2xl font-bold text-white mb-2">Plataforma SaaS Enterprise</h3>
            <p class="text-gray-400 font-light leading-relaxed group-hover:text-gray-300 transition-colors duration-300">
              Plataforma completa de gestión de proyectos con autenticación avanzada, panel en tiempo real y API robusta para integraciones.
            </p>
          </div>
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="px-4 py-2 bg-accent-primary/10 text-accent-primary text-sm font-semibold rounded-full border border-accent-primary/20 hover:bg-accent-primary/20 transition-all duration-300">React</span>
            <span class="px-4 py-2 bg-accent-primary/10 text-accent-primary text-sm font-semibold rounded-full border border-accent-primary/20 hover:bg-accent-primary/20 transition-all duration-300">Node.js</span>
            <span class="px-4 py-2 bg-accent-primary/10 text-accent-primary text-sm font-semibold rounded-full border border-accent-primary/20 hover:bg-accent-primary/20 transition-all duration-300">MongoDB</span>
          </div>
          <a href="#" class="inline-flex items-center text-accent-primary hover:text-accent-secondary transition-colors duration-300 font-semibold">
            Ver proyecto en vivo →
          </a>
        </div>
      </div>

      <!-- Project 2 -->
      <div class="group bg-white/5 rounded-xl overflow-hidden border border-gray-800 hover:border-accent-primary/50 transition-all duration-300 hover:shadow-lg hover:shadow-accent-primary/20">
        <div class="h-56 bg-gradient-to-br from-accent-primary/30 to-accent-secondary/20 border-b border-gray-800 flex items-center justify-center overflow-hidden relative">
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
        </div>
        <div class="p-8 relative z-10">
          <div class="mb-4">
            <h3 class="text-2xl font-bold text-white mb-2">Portafolio Personal</h3>
            <p class="text-gray-400 font-light leading-relaxed group-hover:text-gray-300 transition-colors duration-300">
              Sitio responsivo con diseño moderno, animaciones fluidas y arquitectura optimizada para rendimiento máximo.
            </p>
          </div>
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="px-4 py-2 bg-accent-primary/10 text-accent-primary text-sm font-semibold rounded-full border border-accent-primary/20 hover:bg-accent-primary/20 transition-all duration-300">Astro</span>
            <span class="px-4 py-2 bg-accent-primary/10 text-accent-primary text-sm font-semibold rounded-full border border-accent-primary/20 hover:bg-accent-primary/20 transition-all duration-300">Tailwind</span>
          </div>
          <a href="#" class="inline-flex items-center text-accent-primary hover:text-accent-secondary transition-colors duration-300 font-semibold">
            Ver código →
          </a>
        </div>
      </div>
    </div>

    <!-- Project 3 - Full Width -->
    <div class="group bg-white/5 rounded-xl overflow-hidden border border-gray-800 hover:border-accent-primary/50 transition-all duration-300 hover:shadow-lg hover:shadow-accent-primary/20 mb-8">
      <div class="lg:grid lg:grid-cols-3">
        <div class="lg:col-span-1 h-56 lg:h-full bg-gradient-to-br from-accent-primary/30 to-accent-secondary/20 border-b lg:border-b-0 lg:border-r border-gray-800 flex items-center justify-center overflow-hidden relative">
          <div class="absolute inset-0 bg-gradient-to-t lg:bg-gradient-to-r from-black/40 to-transparent"></div>
        </div>
        <div class="lg:col-span-2 p-8 relative z-10">
          <h3 class="text-2xl font-bold text-white mb-2">Aplicación Móvil Cross-Platform</h3>
          <p class="text-gray-400 font-light leading-relaxed mb-6 group-hover:text-gray-300 transition-colors duration-300">
            Aplicación nativa funcionando en iOS y Android con sincronización en tiempo real en la nube, notificaciones push y experiencia offline completa.
          </p>
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="px-4 py-2 bg-accent-primary/10 text-accent-primary text-sm font-semibold rounded-full border border-accent-primary/20 hover:bg-accent-primary/20 transition-all duration-300">React Native</span>
            <span class="px-4 py-2 bg-accent-primary/10 text-accent-primary text-sm font-semibold rounded-full border border-accent-primary/20 hover:bg-accent-primary/20 transition-all duration-300">Firebase</span>
            <span class="px-4 py-2 bg-accent-primary/10 text-accent-primary text-sm font-semibold rounded-full border border-accent-primary/20 hover:bg-accent-primary/20 transition-all duration-300">Expo</span>
          </div>
          <a href="#" class="inline-flex items-center text-accent-primary hover:text-accent-secondary transition-colors duration-300 font-semibold">
            Ver en App Store →
          </a>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center">
      <p class="text-gray-400 font-light mb-6 hover:text-gray-300 transition-colors duration-300">
        ¿Interesado en ver más trabajos?
      </p>
      <a href="https://github.com/Xharless" target="_blank" class="inline-flex items-center px-8 py-4 bg-accent-primary text-black rounded-lg font-semibold hover:bg-accent-primary/90 transition-all duration-300 shadow-lg shadow-accent-primary/30">
        Visita mi GitHub →
      </a>
    </div>
  </div>
</section>
