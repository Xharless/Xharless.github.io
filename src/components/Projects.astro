---
---

<section id="proyectos" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="mb-12">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Proyectos Destacados</h2>
      <div class="w-20 h-1 bg-gradient-to-r from-indigo-600 to-pink-600 rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Project Card 1 -->
      <div class="group bg-white rounded-xl overflow-hidden border border-slate-200 hover:border-indigo-600 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
        <div class="h-48 bg-gradient-to-br from-indigo-600 to-pink-600 relative overflow-hidden">
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 bg-black/20 transition-opacity duration-300"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-4xl">💼</span>
          </div>
        </div>
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2 text-slate-900">Plataforma SaaS</h3>
          <p class="text-slate-600 mb-4 text-sm leading-relaxed">
            Plataforma de gestión de proyectos con autenticación y panel de control en tiempo real.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-3 py-1 bg-indigo-100 text-indigo-700 text-xs font-semibold rounded-full">React</span>
            <span class="px-3 py-1 bg-pink-100 text-pink-700 text-xs font-semibold rounded-full">Node.js</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-xs font-semibold rounded-full">MongoDB</span>
          </div>
          <a href="#" class="inline-flex items-center text-indigo-600 font-semibold hover:text-pink-600 transition-colors group/link">
            Ver Proyecto
            <svg class="w-4 h-4 ml-2 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Project Card 2 -->
      <div class="group bg-white rounded-xl overflow-hidden border border-slate-200 hover:border-indigo-600 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
        <div class="h-48 bg-gradient-to-br from-slate-600 to-slate-700 relative overflow-hidden">
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 bg-black/20 transition-opacity duration-300"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-4xl">🎨</span>
          </div>
        </div>
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2 text-slate-900">Portafolio Web</h3>
          <p class="text-slate-600 mb-4 text-sm leading-relaxed">
            Sitio web responsivo con diseño moderno y animaciones fluidas.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-3 py-1 bg-indigo-100 text-indigo-700 text-xs font-semibold rounded-full">Astro</span>
            <span class="px-3 py-1 bg-pink-100 text-pink-700 text-xs font-semibold rounded-full">Tailwind</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-xs font-semibold rounded-full">TypeScript</span>
          </div>
          <a href="#" class="inline-flex items-center text-indigo-600 font-semibold hover:text-pink-600 transition-colors group/link">
            Ver Proyecto
            <svg class="w-4 h-4 ml-2 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Project Card 3 -->
      <div class="group bg-white rounded-xl overflow-hidden border border-slate-200 hover:border-indigo-600 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
        <div class="h-48 bg-gradient-to-br from-emerald-600 to-emerald-700 relative overflow-hidden">
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 bg-black/20 transition-opacity duration-300"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-4xl">📱</span>
          </div>
        </div>
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2 text-slate-900">Aplicación Móvil</h3>
          <p class="text-slate-600 mb-4 text-sm leading-relaxed">
            App nativa con funcionalidades offline y sincronización en la nube.
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-3 py-1 bg-indigo-100 text-indigo-700 text-xs font-semibold rounded-full">React Native</span>
            <span class="px-3 py-1 bg-pink-100 text-pink-700 text-xs font-semibold rounded-full">Firebase</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-xs font-semibold rounded-full">Redux</span>
          </div>
          <a href="#" class="inline-flex items-center text-indigo-600 font-semibold hover:text-pink-600 transition-colors group/link">
            Ver Proyecto
            <svg class="w-4 h-4 ml-2 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 text-center">
      <a href="#" class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-indigo-600 to-pink-600 text-white rounded-lg font-semibold hover:shadow-xl hover:shadow-indigo-600/50 transition-all duration-300 transform hover:-translate-y-1">
        Ver Más Proyectos
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
