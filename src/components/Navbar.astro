---

<nav class="sticky top-0 z-50 bg-white shadow-lg border-b border-slate-200">
  <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="text-2xl font-bold bg-gradient-to-r from-indigo-600 to-pink-600 bg-clip-text text-transparent">
      Xharless
    </a>
    <ul class="hidden md:flex gap-8">
      <li>
        <a href="#inicio" class="nav-link text-slate-600 hover:text-indigo-600 transition-colors font-medium">
          Inicio
        </a>
      </li>
      <li>
        <a href="#sobre" class="nav-link text-slate-600 hover:text-indigo-600 transition-colors font-medium">
          Sobre Mí
        </a>
      </li>
      <li>
        <a href="#habilidades" class="nav-link text-slate-600 hover:text-indigo-600 transition-colors font-medium">
          Habilidades
        </a>
      </li>
      <li>
        <a href="#proyectos" class="nav-link text-slate-600 hover:text-indigo-600 transition-colors font-medium">
          Proyectos
        </a>
      </li>
      <li>
        <a href="#contacto" class="nav-link text-slate-600 hover:text-indigo-600 transition-colors font-medium">
          Contacto
        </a>
      </li>
    </ul>
    <button class="md:hidden text-slate-600 hover:text-indigo-600 transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>
</nav>

<script>
  // Actualizar nav links activos
  document.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', function() {
      document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('text-indigo-600'));
      this.classList.add('text-indigo-600');
    });
  });

  // Detección de scroll para actualizar nav
  window.addEventListener('scroll', () => {
    const sections = document.querySelectorAll('section[id]');
    let current = '';

    sections.forEach(section => {
      const sectionTop = section.offsetTop;
      const sectionHeight = section.clientHeight;
      if (window.scrollY >= sectionTop - 200) {
        current = section.getAttribute('id');
      }
    });

    document.querySelectorAll('.nav-link').forEach(link => {
      link.classList.remove('text-indigo-600');
      if (current && link.getAttribute('href') === `#${current}`) {
        link.classList.add('text-indigo-600');
      }
    });
  });
</script>
