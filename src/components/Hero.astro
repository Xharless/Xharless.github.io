---
---

<section id="inicio" class="min-h-screen bg-dark-900 flex items-center justify-center relative overflow-hidden pt-20">
  <!-- Elementos decorativos sutiles -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-accent-primary rounded-full mix-blend-multiply filter blur-3xl opacity-5"></div>
    <div class="absolute bottom-1/4 left-1/4 w-96 h-96 bg-accent-secondary rounded-full mix-blend-multiply filter blur-3xl opacity-5"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 relative z-10 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    <!-- Contenido -->
    <div class="animate-slide-up" style="animation-delay: 0s;">
      <div class="mb-6 inline-block px-4 py-2 bg-dark-800 rounded-full border border-dark-700 hover:border-accent-primary/30 transition-all duration-300">
        <span class="text-accent-primary text-sm font-semibold">👋 Bienvenido</span>
      </div>
      
      <h1 class="text-5xl md:text-6xl font-bold mb-6 leading-tight text-dark-50">
        Hola, soy <span class="text-accent-primary">Carlos</span>
      </h1>
      
      <p class="text-xl md:text-2xl text-dark-300 mb-4 font-semibold">
        Desarrollador Full Stack
      </p>
      
      <p class="text-dark-400 text-lg mb-8 max-w-md leading-relaxed">
        Creo soluciones digitales elegantes con tecnología moderna y atención al detalle.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 mb-8">
        <a 
          href="#proyectos" 
          class="px-8 py-3 bg-accent-primary text-dark-900 rounded-lg font-semibold hover:bg-accent-primary/90 transition-all duration-300 transform hover:scale-105 text-center"
        >
          Explorar Proyectos
        </a>
        <a 
          href="#contacto" 
          class="px-8 py-3 border border-dark-700 text-dark-300 rounded-lg font-semibold hover:border-accent-primary hover:text-accent-primary transition-all duration-300 transform hover:scale-105 text-center"
        >
          Contactarme
        </a>
      </div>

      <!-- Redes sociales -->
      <div class="flex gap-4">
        <a href="#" class="w-10 h-10 rounded-lg bg-dark-800 border border-dark-700 flex items-center justify-center hover:border-accent-primary hover:bg-dark-700/50 transition-all duration-300 transform hover:scale-110">
          <svg class="w-5 h-5 text-dark-400 hover:text-accent-primary transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a href="#" class="w-10 h-10 rounded-full bg-indigo-600/20 border border-indigo-500/30 flex items-center justify-center hover:bg-indigo-600/40 transition-all duration-300 transform hover:-translate-y-1">
          <svg class="w-5 h-5 text-indigo-300" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>
        <a href="#" class="w-10 h-10 rounded-full bg-indigo-600/20 border border-indigo-500/30 flex items-center justify-center hover:bg-indigo-600/40 transition-all duration-300 transform hover:-translate-y-1">
          <svg class="w-5 h-5 text-indigo-300" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.953 4.57a10 10 0 002.856-3.51 9.95 9.95 0 01-2.8.856 4.958 4.958 0 002.165-2.724c-.951.564-2.005.974-3.127 1.195a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Imagen decorativa -->
    <div class="hidden md:block">
      <div class="w-full aspect-square bg-gradient-to-br from-indigo-600 to-pink-600 rounded-2xl shadow-2xl animate-float relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>
