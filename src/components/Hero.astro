---
---

<section id="inicio" class="relative w-full min-h-[100svh] flex flex-col justify-center overflow-hidden">
  <!-- Dynamic Mouse Follower (Flashlight) - Cyber Dark Mode -->
  <div id="flashlight" class="fixed top-0 left-0 w-[60vw] h-[60vw] md:w-[40vw] md:h-[40vw] rounded-full bg-fuchsia-600/20 blur-[100px] md:blur-[140px] pointer-events-none transition-opacity duration-300 opacity-0 z-0 mix-blend-screen will-change-transform"></div>

  <!-- Cyber Grid -->
  <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] z-0 [mask-image:radial-gradient(ellipse_at_center,black_20%,transparent_70%)]"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 w-full flex flex-col lg:flex-row items-center justify-between gap-12 pt-20">
    
    <!-- Left: Content -->
    <div class="flex-1 text-left">
      <div class="reveal reveal-blur delay-100 mb-6">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-fuchsia-500/30 bg-fuchsia-500/10 text-fuchsia-300 text-xs font-semibold tracking-wider uppercase">
          <span class="w-2 h-2 rounded-full bg-fuchsia-500 animate-pulse"></span>
          System Online
        </div>
      </div>

      <h1 class="font-display font-bold leading-[1.1] tracking-tighter text-6xl sm:text-7xl lg:text-8xl text-white mb-6 reveal delay-200">
        Construyendo <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-fuchsia-400 to-purple-500">
          el Futuro.
        </span>
      </h1>

      <p class="text-lg md:text-xl text-zinc-400 font-light leading-relaxed max-w-xl reveal delay-300 mb-10">
        Soy Carlos, un Ingeniero de Software especializado en crear experiencias digitales inmersivas y arquitecturas robustas.
      </p>

      <div class="reveal delay-400 flex flex-wrap gap-4">
        <a href="#proyectos" class="inline-flex items-center justify-center px-8 py-4 bg-white text-black font-display font-bold rounded-lg hover:bg-zinc-200 transition-colors shadow-[0_0_20px_-5px_rgba(255,255,255,0.4)]">
          Desplegar Proyectos
        </a>
        <a href="#contacto" class="inline-flex items-center justify-center px-8 py-4 bg-white/5 border border-white/10 text-white font-display font-bold rounded-lg hover:bg-white/10 transition-colors">
          Contactar
        </a>
      </div>
    </div>

    <!-- Right: Glass Terminal -->
    <div class="flex-1 w-full max-w-lg lg:max-w-none reveal reveal-scale delay-500 relative perspective-1000">
      <div class="absolute -inset-1 bg-gradient-to-r from-cyan-500 to-fuchsia-500 rounded-2xl blur opacity-30 animate-pulse"></div>
      <div class="relative rounded-2xl bg-[#0a0a0a]/80 backdrop-blur-xl border border-white/10 overflow-hidden shadow-2xl transition-transform duration-700 hover:scale-[1.02]">
        <div class="flex items-center px-4 py-3 border-b border-white/10 bg-white/5">
          <div class="flex gap-2">
            <div class="w-3 h-3 rounded-full bg-rose-500"></div>
            <div class="w-3 h-3 rounded-full bg-amber-500"></div>
            <div class="w-3 h-3 rounded-full bg-emerald-500"></div>
          </div>
          <div class="mx-auto text-xs font-mono text-zinc-500">carlos@sys:~</div>
        </div>
        <div class="p-6 font-mono text-sm sm:text-base text-zinc-300">
          <p class="mb-2"><span class="text-fuchsia-400">const</span> <span class="text-cyan-400">developer</span> = {"{"}</p>
          <p class="ml-4 mb-1">name: <span class="text-amber-300">"Carlos"</span>,</p>
          <p class="ml-4 mb-1">role: <span class="text-amber-300">"Software Engineer"</span>,</p>
          <p class="ml-4 mb-1">focus: [<span class="text-amber-300">"Frontend"</span>, <span class="text-amber-300">"UI/UX"</span>],</p>
          <p class="ml-4 mb-2">passion: <span class="text-amber-300">true</span></p>
          <p class="mb-4">{"}"};</p>
          <p class="flex items-center"><span class="text-emerald-400 mr-2">➜</span> <span class="animate-pulse">_</span></p>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .perspective-1000 { perspective: 1000px; }
</style>

<script>
  // Flashlight Effect Setup
  const flashlight = document.getElementById('flashlight');
  let mouseX = window.innerWidth / 2;
  let mouseY = window.innerHeight / 2;
  let currentX = mouseX;
  let currentY = mouseY;
  let isHovering = false;

  document.addEventListener('mousemove', (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
    
    if (flashlight && !isHovering) {
      flashlight.style.opacity = '1';
      isHovering = true;
    }
  });

  document.addEventListener('mouseleave', () => {
    if (flashlight) {
      flashlight.style.opacity = '0';
      isHovering = false;
    }
  });

  function animateFlashlight() {
    // Smooth trailing physics
    currentX += (mouseX - currentX) * 0.15;
    currentY += (mouseY - currentY) * 0.15;

    if (flashlight) {
      flashlight.style.transform = `translate3d(calc(${currentX}px - 50%), calc(${currentY}px - 50%), 0)`;
    }

    requestAnimationFrame(animateFlashlight);
  }

  animateFlashlight();
</script>

