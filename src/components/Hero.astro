---
---

<section id="inicio" class="min-h-screen bg-black flex items-center justify-center relative overflow-hidden pt-32 pb-20">
  <!-- Decorative elements - Optimized for performance -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-accent-primary rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-float-subtle"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-accent-secondary rounded-full mix-blend-multiply filter blur-3xl opacity-10 animate-sway"></div>
  </div>

  <div class="max-w-5xl mx-auto px-6 relative z-10 text-center space-y-8">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 glass rounded-full border border-gray-700 animate-fade-in smooth-transition hover:border-accent-primary/70 hover:bg-accent-primary/5">
      <span class="w-2 h-2 bg-accent-primary rounded-full animate-pulse-glow"></span>
      <span class="text-sm text-gray-300 font-light">Bienvenido a mi portafolio</span>
    </div>

    <!-- Main headline -->
    <div class="animate-slide-up" style="animation-delay: 0.1s;">
      <h1 class="text-6xl md:text-7xl lg:text-8xl font-bold text-white leading-tight mb-6 smooth-transition">
        Desarrollo
        <span class="block">
          <span class="inline-block">
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-primary via-accent-secondary to-accent-primary animate-pulse-glow">
              Web Moderno
            </span>
          </span>
        </span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-400 font-light max-w-2xl mx-auto leading-relaxed smooth-transition hover:text-gray-300">
        Creo experiencias digitales elegantes que transforman ideas en realidad
      </p>
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center pt-8 animate-slide-up smooth-transition" style="animation-delay: 0.2s;">
      <a href="#proyectos" class="group px-8 py-4 bg-accent-primary text-black rounded-xl font-semibold hover:bg-accent-primary/90 transition-all duration-300 transform hover:scale-105 shadow-xl shadow-accent-primary/30 smooth-fast flex items-center gap-2 will-change-transform">
        Ver mis trabajos
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
      </a>
      <a href="#contacto" class="px-8 py-4 border border-gray-600 text-white rounded-xl font-semibold hover:border-accent-primary hover:bg-accent-primary/5 transition-all duration-300 transform hover:scale-105 smooth-fast will-change-transform">
        Ponerse en contacto
      </a>
    </div>

    <!-- Social links -->
    <div class="flex gap-3 justify-center pt-8 animate-slide-up smooth-transition" style="animation-delay: 0.3s;">
      <a href="#" class="w-11 h-11 glass rounded-lg border border-gray-700 flex items-center justify-center hover:border-accent-primary hover:bg-accent-primary/10 transition-all transform hover:scale-110 smooth-fast will-change-transform">
        <svg class="w-5 h-5 text-gray-400 hover:text-accent-primary transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
      <a href="#" class="w-11 h-11 glass rounded-lg border border-gray-700 flex items-center justify-center hover:border-accent-primary hover:bg-accent-primary/10 transition-all transform hover:scale-110 smooth-fast will-change-transform">
        <svg class="w-5 h-5 text-gray-400 hover:text-accent-primary transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
      </a>
      <a href="#" class="w-11 h-11 glass rounded-lg border border-gray-700 flex items-center justify-center hover:border-accent-primary hover:bg-accent-primary/10 transition-all transform hover:scale-110 smooth-fast will-change-transform">
        <svg class="w-5 h-5 text-gray-400 hover:text-accent-primary transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 002.856-3.51 9.95 9.95 0 01-2.8.856 4.958 4.958 0 002.165-2.724c-.951.564-2.005.974-3.127 1.195a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417a9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </div>
</section>
