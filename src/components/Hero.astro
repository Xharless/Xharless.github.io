---

<section id="inicio" class="min-h-screen bg-black flex items-center justify-center relative overflow-hidden pt-32 pb-20">
  <div class="max-w-5xl mx-auto px-6 relative z-10 text-center space-y-8">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 glass rounded-full border border-gray-700 smooth-transition hover:border-accent-primary/70 hover:bg-accent-primary/5">
      <span class="text-sm text-gray-300 font-light">Bienvenido a mi portafolio</span>
    </div>

    <!-- Main headline -->
    <div>
      <h1 class="text-6xl md:text-7xl lg:text-8xl font-bold text-white leading-tight mb-6 smooth-transition">
        Desarrollo
        <span class="block text-accent-primary">
          Web Moderno
        </span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-400 font-light max-w-2xl mx-auto leading-relaxed smooth-transition hover:text-gray-300">
        Creo experiencias digitales elegantes que transforman ideas en realidad
      </p>
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center pt-8 smooth-transition">
      <a href="#proyectos" class="px-8 py-4 bg-accent-primary text-black rounded-xl font-semibold hover:bg-accent-primary/90 smooth-fast">
        Ver mis trabajos
      </a>
      <a href="#contacto" class="px-8 py-4 border border-gray-600 text-white rounded-xl font-semibold hover:border-accent-primary hover:bg-accent-primary/5 smooth-fast">
        Ponerse en contacto
      </a>
    </div>
  </div>
</section>
