---
const categories = [
  {
    title: "Frontend",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-400"><rect width="18" height="7" x="3" y="3" rx="1"/><rect width="9" height="7" x="3" y="14" rx="1"/><rect width="5" height="7" x="16" y="14" rx="1"/></svg>`,
    skills: ["TypeScript", "React", "Next.js", "Astro", "Tailwind CSS"],
    glow: "from-cyan-500/10 to-blue-500/10",
    borderHover: "hover:border-cyan-500/50"
  },
  {
    title: "Backend",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-fuchsia-400"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/></svg>`,
    skills: ["Node.js", "Python", "PostgreSQL", "REST APIs", "GraphQL"],
    glow: "from-fuchsia-500/10 to-purple-500/10",
    borderHover: "hover:border-fuchsia-500/50"
  },
  {
    title: "DevOps",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-400"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>`,
    skills: ["Git", "GitHub Actions", "Docker", "AWS", "Vercel"],
    glow: "from-emerald-500/10 to-teal-500/10",
    borderHover: "hover:border-emerald-500/50"
  },
  {
    title: "Design",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400"><path d="m12 19 7-7 3 3-7 7-3-3z"/><path d="m18 13-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="m2 2 7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>`,
    skills: ["UI/UX", "Figma", "Prototyping", "Design Systems"],
    glow: "from-amber-500/10 to-orange-500/10",
    borderHover: "hover:border-amber-500/50"
  }
];

const techStack = [
  { name: "TypeScript", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/typescript/typescript-original.svg" },
  { name: "React", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/react/react-original.svg" },
  { name: "Next.js", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nextjs/nextjs-original.svg" },
  { name: "Astro", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/astro/astro-original.svg" },
  { name: "Node.js", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original.svg" },
  { name: "PostgreSQL", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/postgresql/postgresql-original.svg" },
  { name: "Docker", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/docker/docker-original.svg" },
  { name: "Git", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/git/git-original.svg" },
  { name: "Figma", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/figma/figma-original.svg" }
];
---

<section id="habilidades" class="relative py-32 px-6 overflow-hidden">
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-16">
    
    <!-- Left: Sticky Title -->
    <div class="lg:w-1/3 lg:sticky lg:top-32 h-fit reveal delay-100">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-cyan-500/30 bg-cyan-500/10 text-cyan-300 text-xs font-semibold tracking-wider uppercase mb-6">
        <span class="w-2 h-2 rounded-full bg-cyan-500"></span>
        Ecosistema
      </div>
      <h2 class="text-4xl md:text-5xl font-display font-bold tracking-tight text-white mb-6">
        Mi <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Arsenal</span> Técnico.
      </h2>
      <p class="text-zinc-400 text-lg leading-relaxed mb-8 font-light">
        Domino las tecnologías modernas necesarias para construir desde la interfaz de usuario más fluida hasta la arquitectura backend más robusta.
      </p>

      <!-- Tech Cloud Minimal -->
      <div class="flex flex-wrap gap-4">
        {techStack.map((tech) => (
          <div class="group relative flex items-center justify-center w-12 h-12 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 hover:scale-110 transition-all duration-300 cursor-default">
            {tech.icon && <img src={tech.icon} alt={tech.name} class="w-6 h-6 opacity-50 group-hover:opacity-100 transition-opacity" loading="lazy" />}
            <div class="absolute -top-10 opacity-0 group-hover:opacity-100 transition-opacity text-[10px] font-medium text-white bg-zinc-800 px-2 py-1 rounded whitespace-nowrap z-20 shadow-xl">
              {tech.name}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: Staggered Cards -->
    <div class="lg:w-2/3 grid grid-cols-1 sm:grid-cols-2 gap-6 relative">
      {categories.map((cat, i) => (
        <div class={`group relative overflow-hidden rounded-2xl bg-[#0a0a0a]/80 backdrop-blur-md border border-white/10 p-8 transition-all duration-300 hover:-translate-y-2 reveal delay-${(i % 2 + 2) * 100} ${i % 2 !== 0 ? 'sm:mt-12' : ''} ${cat.borderHover}`}>
          <!-- Hover Glow -->
          <div class={`absolute inset-0 bg-gradient-to-br ${cat.glow} opacity-0 group-hover:opacity-100 transition-opacity duration-500`}></div>
          
          <div class="relative z-10">
            <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-2xl mb-6 shadow-xl group-hover:scale-110 transition-transform duration-300">
              <Fragment set:html={cat.icon} />
            </div>
            <h3 class="text-2xl font-display font-bold text-white mb-6">{cat.title}</h3>
            <ul class="space-y-3">
              {cat.skills.map((skill) => (
                <li class="flex items-center text-zinc-400 group-hover:text-zinc-200 transition-colors">
                  <span class="w-1.5 h-1.5 rounded-full bg-white/20 group-hover:bg-white/80 mr-3 transition-colors"></span>
                  {skill}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
    
  </div>
</section>
