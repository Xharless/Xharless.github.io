---
---

<section id="habilidades" class="py-24 bg-dark-800/50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="mb-16 animate-slide-up">
      <h2 class="text-4xl md:text-5xl font-bold mb-4 text-dark-50">Habilidades</h2>
      <div class="w-20 h-1 bg-accent-primary rounded-full"></div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-16">
      <div class="group p-6 bg-dark-800 rounded-xl border border-dark-700 hover:border-accent-primary/50 transition-all duration-300 text-center hover:bg-dark-700/50 cursor-pointer animate-scale-in" style="animation-delay: 0s;">
        <div class="w-16 h-16 bg-accent-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-2xl">🚀</span>
        </div>
        <h3 class="font-semibold text-dark-50 mb-2">Astro</h3>
        <p class="text-sm text-dark-400">Experto</p>
      </div>

      <div class="group p-6 bg-dark-800 rounded-xl border border-dark-700 hover:border-accent-primary/50 transition-all duration-300 text-center hover:bg-dark-700/50 cursor-pointer animate-scale-in" style="animation-delay: 0.1s;">
        <div class="w-16 h-16 bg-accent-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-2xl">⚛️</span>
        </div>
        <h3 class="font-semibold text-dark-50 mb-2">React</h3>
        <p class="text-sm text-dark-400">Experto</p>
      </div>

      <div class="group p-6 bg-dark-800 rounded-xl border border-dark-700 hover:border-accent-primary/50 transition-all duration-300 text-center hover:bg-dark-700/50 cursor-pointer animate-scale-in" style="animation-delay: 0.2s;">
        <div class="w-16 h-16 bg-accent-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-2xl">🎨</span>
        </div>
        <h3 class="font-semibold text-dark-50 mb-2">Tailwind</h3>
        <p class="text-sm text-dark-400">Experto</p>
      </div>

      <div class="group p-6 bg-dark-800 rounded-xl border border-dark-700 hover:border-accent-primary/50 transition-all duration-300 text-center hover:bg-dark-700/50 cursor-pointer animate-scale-in" style="animation-delay: 0.3s;">
        <div class="w-16 h-16 bg-accent-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-2xl">🔧</span>
        </div>
        <h3 class="font-semibold text-dark-50 mb-2">TypeScript</h3>
        <p class="text-sm text-dark-400">Experto</p>
      </div>

      <div class="group p-6 bg-dark-800 rounded-xl border border-dark-700 hover:border-accent-primary/50 transition-all duration-300 text-center hover:bg-dark-700/50 cursor-pointer animate-scale-in" style="animation-delay: 0.4s;">
        <div class="w-16 h-16 bg-accent-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-2xl">🗄️</span>
        </div>
        <h3 class="font-semibold text-dark-50 mb-2">Node.js</h3>
        <p class="text-sm text-dark-400">Experto</p>
      </div>

      <div class="group p-6 bg-dark-800 rounded-xl border border-dark-700 hover:border-accent-primary/50 transition-all duration-300 text-center hover:bg-dark-700/50 cursor-pointer animate-scale-in" style="animation-delay: 0.5s;">
        <div class="w-16 h-16 bg-accent-primary/10 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-2xl">📦</span>
        </div>
        <h3 class="font-semibold text-dark-50 mb-2">MongoDB</h3>
        <p class="text-sm text-dark-400">Experto</p>
      </div>
    </div>

    <div class="space-y-6">
      <div class="animate-slide-up" style="animation-delay: 0.1s;">
        <div class="flex items-center justify-between mb-3">
          <h4 class="font-semibold text-dark-50">Frontend</h4>
          <span class="text-sm font-semibold text-accent-primary">95%</span>
        </div>
        <div class="w-full h-2 bg-dark-700 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-accent-primary to-accent-secondary rounded-full w-[95%] transition-all duration-1000"></div>
        </div>
      </div>

      <div class="animate-slide-up" style="animation-delay: 0.2s;">
        <div class="flex items-center justify-between mb-3">
          <h4 class="font-semibold text-dark-50">Backend</h4>
          <span class="text-sm font-semibold text-accent-primary">85%</span>
        </div>
        <div class="w-full h-2 bg-dark-700 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-accent-primary to-accent-secondary rounded-full w-[85%] transition-all duration-1000"></div>
        </div>
      </div>

      <div class="animate-slide-up" style="animation-delay: 0.3s;">
        <div class="flex items-center justify-between mb-3">
          <h4 class="font-semibold text-dark-50">UI/UX Design</h4>
          <span class="text-sm font-semibold text-accent-primary">90%</span>
        </div>
        <div class="w-full h-2 bg-dark-700 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-accent-primary to-accent-secondary rounded-full w-[90%] transition-all duration-1000"></div>
        </div>
      </div>
    </div>
  </div>
</section>
