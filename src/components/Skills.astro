---
const skills = [
  {
    category: "Frontend",
    icon: "🎨",
    color: "#0a84ff",
    items: [
      { name: "TypeScript", level: 90 },
      { name: "React / Next.js", level: 88 },
      { name: "Astro", level: 82 },
      { name: "Tailwind CSS", level: 92 },
    ],
  },
  {
    category: "Backend",
    icon: "⚙️",
    color: "#bf5af2",
    items: [
      { name: "Node.js", level: 85 },
      { name: "Python", level: 78 },
      { name: "PostgreSQL", level: 80 },
      { name: "REST / GraphQL", level: 84 },
    ],
  },
  {
    category: "Herramientas",
    icon: "🛠",
    color: "#30d158",
    items: [
      { name: "Git / GitHub", level: 94 },
      { name: "Docker", level: 72 },
      { name: "Figma", level: 76 },
      { name: "CI/CD", level: 70 },
    ],
  },
];

const techStack = [
  { name: "TypeScript", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/typescript/typescript-original.svg" },
  { name: "React", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/react/react-original.svg" },
  { name: "Next.js", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nextjs/nextjs-original.svg" },
  { name: "Astro", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/astro/astro-original.svg" },
  { name: "Node.js", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original.svg" },
  { name: "Python", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/python/python-original.svg" },
  { name: "PostgreSQL", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/postgresql/postgresql-original.svg" },
  { name: "Docker", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/docker/docker-original.svg" },
  { name: "Git", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/git/git-original.svg" },
  { name: "Tailwind", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/tailwindcss/tailwindcss-original.svg" },
  { name: "Figma", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/figma/figma-original.svg" }
];
---

<section id="habilidades" class="skills section">
  <div class="container">
    <div class="section-label reveal">Habilidades</div>
    <h2 class="section-title reveal reveal-delay-1">
      Mi stack técnico
    </h2>
    <p class="section-subtitle reveal reveal-delay-2">
      Herramientas y tecnologías con las que construyo día a día.
    </p>

    <div class="skills-grid">
      {skills.map((group, gi) => (
        <div
          class={`skill-card glass-card reveal reveal-delay-${gi + 2}`}
          style={`--card-accent: ${group.color};`}
        >
          <div class="skill-card-header">
            <span class="skill-icon">{group.icon}</span>
            <span class="skill-category">{group.category}</span>
          </div>

          <div class="skill-items">
            {group.items.map((item) => (
              <div class="skill-item">
                <div class="skill-meta">
                  <span class="skill-name">{item.name}</span>
                  <span class="skill-pct">{item.level}%</span>
                </div>
                <div class="skill-bar">
                  <div
                    class="skill-fill"
                    data-level={item.level}
                    style={`--target: ${item.level}%; --accent: ${group.color};`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Tech pill cloud -->
    <div class="tech-cloud reveal reveal-delay-3">
      <div class="tech-cloud-label">También trabajo con</div>
      <div class="tech-pills">
        {techStack.map((tech) => (
          <span class="tech-pill">
            {tech.icon && <img src={tech.icon} alt={tech.name} class="tech-icon" loading="lazy" />}
            {tech.name}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .skills {
    padding: 120px 24px;
    background: linear-gradient(180deg, transparent 0%, rgba(10, 132, 255, 0.02) 50%, transparent 100%);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--text-primary);
    margin-bottom: 16px;
  }

  .section-subtitle {
    color: var(--text-secondary);
    font-size: 1.0625rem;
    margin-bottom: 64px;
    font-weight: 300;
    max-width: 500px;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 48px;
  }

  @media (max-width: 900px) { .skills-grid { grid-template-columns: 1fr; } }

  .skill-card {
    border-radius: 20px;
    padding: 28px;
    position: relative;
    overflow: hidden;
  }

  .skill-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--card-accent);
    opacity: 0.5;
    transition: opacity 0.3s ease;
  }

  .skill-card:hover::before {
    opacity: 1;
  }

  .skill-card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .skill-icon {
    font-size: 1.5rem;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface-hover);
    border-radius: 12px;
  }

  .skill-category {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .skill-items {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .skill-item {}

  .skill-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .skill-name {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .skill-pct {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-tertiary);
    font-variant-numeric: tabular-nums;
  }

  .skill-bar {
    height: 4px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 4px;
    overflow: hidden;
  }

  .skill-fill {
    height: 100%;
    width: 0;
    border-radius: 4px;
    background: var(--accent);
    transition: width 1.2s var(--ease-out-expo);
  }

  .skill-fill.animated {
    width: var(--target);
    background: linear-gradient(90deg, var(--accent), color-mix(in srgb, var(--accent) 70%, white));
  }

  /* Tech cloud */
  .tech-cloud {
    padding: 32px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
  }

  .tech-cloud-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 16px;
  }

  .tech-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .tech-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px; /* Espacio entre el logo y el texto */
    padding: 8px 16px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 100px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: default;
    animation: float 4s ease-in-out infinite;
  }
  .tech-pill:nth-child(odd) {
    animation-duration: 5s;
    animation-delay: 0.5s;
  }
  .tech-pill:nth-child(even) {
    animation-duration: 4.5s;
    animation-delay: 0.2s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }
  .tech-icon {
    width: 16px;
    height: 16px;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.6);
    transition: all 0.3s ease;
  }
  .tech-pill:hover {
    color: var(--text-primary);
    border-color: var(--accent);
    background: rgba(10, 132, 255, 0.08);
    transform: translateY(-4px) scale(1.05); 
    box-shadow: 0 8px 24px rgba(10, 132, 255, 0.2);
    animation-play-state: paused; 
    z-index: 10;
  }

  .tech-pill:hover .tech-icon {
    filter: grayscale(0%) opacity(1);
  }
</style>

<script>
  // Animate skill bars on intersection
  const fills = document.querySelectorAll<HTMLElement>(".skill-fill");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const fill = entry.target as HTMLElement;
          setTimeout(() => fill.classList.add("animated"), 200);
          observer.unobserve(fill);
        }
      });
    },
    { threshold: 0.5 }
  );

  fills.forEach((fill) => observer.observe(fill));
</script>
