<section id="habilidades" class="py-32 px-6 relative overflow-hidden">
  <div class="max-w-6xl mx-auto">
    <!-- Título -->
    <div class="mb-20 text-center animate-slide-up">
      <h2 class="text-5xl md:text-6xl font-bold mb-6 text-white">
        Tecnologías & Lenguajes
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto leading-relaxed font-light">
        Herramientas y lenguajes con los que construyo soluciones modernas y escalables
