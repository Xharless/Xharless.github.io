---
---

<section id="habilidades" class="py-20 bg-gradient-to-b from-slate-50 to-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="mb-12">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Habilidades</h2>
      <div class="w-20 h-1 bg-gradient-to-r from-indigo-600 to-pink-600 rounded-full"></div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      <!-- Skill cards -->
      <div class="group p-6 bg-white rounded-xl border border-slate-200 hover:border-indigo-600 hover:shadow-lg transition-all duration-300 text-center hover:-translate-y-2">
        <div class="w-16 h-16 bg-gradient-to-br from-indigo-100 to-pink-100 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-2xl">🚀</span>
        </div>
        <h3 class="font-semibold text-slate-900 mb-2">Astro</h3>
        <p class="text-sm text-slate-600">Framework moderno</p>
      </div>

      <div class="group p-6 bg-white rounded-xl border border-slate-200 hover:border-indigo-600 hover:shadow-lg transition-all duration-300 text-center hover:-translate-y-2">
        <div class="w-16 h-16 bg-gradient-to-br from-indigo-100 to-pink-100 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-2xl">⚛️</span>
        </div>
        <h3 class="font-semibold text-slate-900 mb-2">React</h3>
        <p class="text-sm text-slate-600">Componentes dinámicos</p>
      </div>

      <div class="group p-6 bg-white rounded-xl border border-slate-200 hover:border-indigo-600 hover:shadow-lg transition-all duration-300 text-center hover:-translate-y-2">
        <div class="w-16 h-16 bg-gradient-to-br from-indigo-100 to-pink-100 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-2xl">🎨</span>
        </div>
        <h3 class="font-semibold text-slate-900 mb-2">Tailwind</h3>
        <p class="text-sm text-slate-600">CSS utility-first</p>
      </div>

      <div class="group p-6 bg-white rounded-xl border border-slate-200 hover:border-indigo-600 hover:shadow-lg transition-all duration-300 text-center hover:-translate-y-2">
        <div class="w-16 h-16 bg-gradient-to-br from-indigo-100 to-pink-100 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-2xl">🔧</span>
        </div>
        <h3 class="font-semibold text-slate-900 mb-2">TypeScript</h3>
        <p class="text-sm text-slate-600">Tipado estático</p>
      </div>

      <div class="group p-6 bg-white rounded-xl border border-slate-200 hover:border-indigo-600 hover:shadow-lg transition-all duration-300 text-center hover:-translate-y-2">
        <div class="w-16 h-16 bg-gradient-to-br from-indigo-100 to-pink-100 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-2xl">🗄️</span>
        </div>
        <h3 class="font-semibold text-slate-900 mb-2">Node.js</h3>
        <p class="text-sm text-slate-600">Backend robusto</p>
      </div>

      <div class="group p-6 bg-white rounded-xl border border-slate-200 hover:border-indigo-600 hover:shadow-lg transition-all duration-300 text-center hover:-translate-y-2">
        <div class="w-16 h-16 bg-gradient-to-br from-indigo-100 to-pink-100 rounded-lg flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
          <span class="text-2xl">📦</span>
        </div>
        <h3 class="font-semibold text-slate-900 mb-2">MongoDB</h3>
        <p class="text-sm text-slate-600">Base de datos flexible</p>
      </div>
    </div>

    <!-- Skills con progreso -->
    <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-8">
      <div>
        <div class="flex items-center justify-between mb-2">
          <h4 class="font-semibold text-slate-900">Frontend Development</h4>
          <span class="text-sm font-semibold text-indigo-600">95%</span>
        </div>
        <div class="w-full h-3 bg-slate-200 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-indigo-600 to-pink-600 rounded-full w-[95%] transition-all duration-1000"></div>
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between mb-2">
          <h4 class="font-semibold text-slate-900">Backend Development</h4>
          <span class="text-sm font-semibold text-indigo-600">85%</span>
        </div>
        <div class="w-full h-3 bg-slate-200 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-indigo-600 to-pink-600 rounded-full w-[85%] transition-all duration-1000"></div>
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between mb-2">
          <h4 class="font-semibold text-slate-900">UI/UX Design</h4>
          <span class="text-sm font-semibold text-indigo-600">90%</span>
        </div>
        <div class="w-full h-3 bg-slate-200 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-indigo-600 to-pink-600 rounded-full w-[90%] transition-all duration-1000"></div>
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between mb-2">
          <h4 class="font-semibold text-slate-900">Gestión de Proyectos</h4>
          <span class="text-sm font-semibold text-indigo-600">88%</span>
        </div>
        <div class="w-full h-3 bg-slate-200 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-indigo-600 to-pink-600 rounded-full w-[88%] transition-all duration-1000"></div>
        </div>
      </div>
    </div>
  </div>
</section>
