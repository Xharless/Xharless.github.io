        <div class="absolute inset-0 bg-gradient-to-br from-accent-primary/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative z-10 text-center">
          <div class="text-4xl mb-2 group-hover:scale-110 transition-transform duration-300">🟨</div>
          <p class="font-semibold text-white group-hover:text-accent-primary transition-colors">JavaScript</p>
          <p class="text-sm text-gray-400">ES6+</p>
        </div>
