      <!-- Herramientas -->
      <div class="glass rounded-2xl p-8 border border-dark-700 hover:border-dark-600 transition-all duration-300 animate-slide-up" style="animation-delay: 0.2s;">
        <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
          <span class="text-2xl">🛠️</span> Herramientas & Plataformas
        </h3>
        <div class="space-y-3">
          <div class="flex items-center justify-between p-3 rounded-lg bg-white/5 hover:bg-white/10 transition-colors">
            <span class="text-gray-300 font-medium">VS Code</span>
            <div class="w-24 h-2 bg-gray-800 rounded-full overflow-hidden">
              <div class="h-full bg-accent-primary/60" style="width: 100%"></div>
            </div>
          </div>
          <div class="flex items-center justify-between p-3 rounded-lg bg-white/5 hover:bg-white/10 transition-colors">
            <span class="text-gray-300 font-medium">GitHub</span>
            <div class="w-24 h-2 bg-gray-800 rounded-full overflow-hidden">
              <div class="h-full bg-accent-primary/60" style="width: 95%"></div>
            </div>
          </div>
          <div class="flex items-center justify-between p-3 rounded-lg bg-white/5 hover:bg-white/10 transition-colors">
            <span class="text-gray-300 font-medium">Docker</span>
            <div class="w-24 h-2 bg-gray-800 rounded-full overflow-hidden">
