---
const svgZap = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-fuchsia-400"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`;
const svgRocket = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-cyan-400"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>`;
const svgStar = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-400"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`;
const svgLaptop = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-400"><path d="M20 16V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9m16 0H4m16 0 1.28 2.55a1 1 0 0 1-.9 1.45H3.62a1 1 0 0 1-.9-1.45L4 16"/></svg>`;

const stats = [
  {
    number: 3,
    suffix: "+",
    label: "Años de experiencia",
    description: "Construyendo productos digitales",
    icon: svgZap,
    colorClass: "text-fuchsia-400",
    glowClass: "group-hover:shadow-[0_0_30px_-5px_rgba(192,38,211,0.3)]",
    lineClass: "bg-gradient-to-r from-transparent via-fuchsia-500 to-transparent",
  },
  {
    number: 20,
    suffix: "+",
    label: "Proyectos completados",
    description: "Desde startups hasta empresas",
    icon: svgRocket,
    colorClass: "text-cyan-400",
    glowClass: "group-hover:shadow-[0_0_30px_-5px_rgba(34,211,238,0.3)]",
    lineClass: "bg-gradient-to-r from-transparent via-cyan-500 to-transparent",
  },
  {
    number: 98,
    suffix: "%",
    label: "Satisfacción de clientes",
    description: "Basado en feedback directo",
    icon: svgStar,
    colorClass: "text-amber-400",
    glowClass: "group-hover:shadow-[0_0_30px_-5px_rgba(251,191,36,0.3)]",
    lineClass: "bg-gradient-to-r from-transparent via-amber-500 to-transparent",
  },
  {
    number: 12,
    suffix: "k+",
    label: "Líneas de código / sem",
    description: "Código limpio y mantenible",
    icon: svgLaptop,
    colorClass: "text-emerald-400",
    glowClass: "group-hover:shadow-[0_0_30px_-5px_rgba(52,211,153,0.3)]",
    lineClass: "bg-gradient-to-r from-transparent via-emerald-500 to-transparent",
  },
];
---

<section class="w-full border-y border-white/5 bg-[#0a0a0a]/50 backdrop-blur-sm relative z-10 overflow-hidden">
  <!-- Top glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-[1px] bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 divide-y sm:divide-y-0 sm:divide-x divide-white/5">
      {stats.map((stat, i) => (
        <div class={`group relative p-8 md:p-12 transition-all duration-500 reveal delay-${(i + 1) * 100} hover:bg-white/5`}>
          <!-- Hover Accent Line -->
          <div class={`absolute bottom-0 left-0 right-0 h-[2px] opacity-0 scale-x-0 group-hover:opacity-100 group-hover:scale-x-100 transition-all duration-500 origin-center ${stat.lineClass}`}></div>

          <div class="mb-4 transform group-hover:scale-110 group-hover:-translate-y-1 transition-all duration-300 inline-block">
            <Fragment set:html={stat.icon} />
          </div>
          
          <div class="flex items-baseline gap-1 mb-2">
            <span class={`stat-number text-4xl md:text-5xl font-display font-bold tabular-nums tracking-tighter ${stat.colorClass} ${stat.glowClass} transition-shadow duration-300 rounded-lg`} data-target={stat.number}>
              0
            </span>
            <span class={`text-xl md:text-2xl font-display font-bold opacity-80 ${stat.colorClass}`}>
              {stat.suffix}
            </span>
          </div>

          <div class="text-sm font-semibold text-white tracking-wide mb-1 uppercase">
            {stat.label}
          </div>
          <div class="text-xs text-zinc-500">
            {stat.description}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function easeOutExpo(t: number): number {
    return t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
  }

  function animateCounter(el: HTMLElement, target: number) {
    const duration = 2000;
    const start = performance.now();

    function tick(now: number) {
      const t = Math.min((now - start) / duration, 1);
      const value = Math.round(easeOutExpo(t) * target);
      el.textContent = String(value);

      if (t < 1) {
        requestAnimationFrame(tick);
      }
    }

    requestAnimationFrame(tick);
  }

  const counters = document.querySelectorAll<HTMLElement>(".stat-number");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.target || "0");
          animateCounter(el, target);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.5 }
  );

  counters.forEach((counter) => observer.observe(counter));
</script>
