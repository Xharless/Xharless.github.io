---
---

<div id="page-loader" class="loader">
  <div class="loader-inner">
    <div class="loader-logo">
      <span class="loader-dot"></span>
      <span class="loader-name">Carlos</span>
    </div>
    <div class="loader-bar-track">
      <div class="loader-bar" id="loaderBar"></div>
    </div>
    <div class="loader-percent" id="loaderPercent">0%</div>
  </div>
</div>

<style>
  .loader {
    position: fixed;
    inset: 0;
    background: #000;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .loader.hidden {
    opacity: 0;
    transform: scale(1.03);
    pointer-events: none;
  }

  .loader-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    width: 220px;
  }

  .loader-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    opacity: 0;
    transform: translateY(12px);
    animation: loaderFadeUp 0.5s 0.1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes loaderFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .loader-dot {
    width: 8px;
    height: 8px;
    background: #0a84ff;
    border-radius: 50%;
    box-shadow: 0 0 14px rgba(10, 132, 255, 0.7);
    animation: loaderPulse 1.2s ease-in-out infinite;
  }

  @keyframes loaderPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .loader-name {
    font-family: "Syne", sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #f5f5f7;
    letter-spacing: -0.03em;
  }

  .loader-bar-track {
    width: 100%;
    height: 2px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 2px;
    overflow: hidden;
    opacity: 0;
    animation: loaderFadeUp 0.5s 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .loader-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #0a84ff, #bf5af2);
    border-radius: 2px;
    transition: width 0.15s ease;
  }

  .loader-percent {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: rgba(245, 245, 247, 0.3);
    font-variant-numeric: tabular-nums;
    opacity: 0;
    animation: loaderFadeUp 0.5s 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>

<script>
  const loader = document.getElementById("page-loader")!;
  const bar = document.getElementById("loaderBar")!;
  const percent = document.getElementById("loaderPercent")!;

  let progress = 0;
  const duration = 1400; // ms
  const start = performance.now();

  // Eased progress curve — fast at start, slow at end (feels premium)
  function easeOutExpo(t: number): number {
    return t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
  }

  function tick(now: number) {
    const elapsed = now - start;
    const t = Math.min(elapsed / duration, 1);
    progress = easeOutExpo(t) * 100;

    bar.style.width = progress + "%";
    percent.textContent = Math.round(progress) + "%";

    if (t < 1) {
      requestAnimationFrame(tick);
    } else {
      // Small pause at 100% then fade out
      setTimeout(() => {
        loader.classList.add("hidden");
        setTimeout(() => loader.remove(), 800);
      }, 300);
    }
  }

  // Start after fonts/DOM ready
  requestAnimationFrame(tick);
</script>
